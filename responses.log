static void SSRRowTask(void *arg)
{
	SSRTask *task = arg;
	int W = task->camera->screenWidth;
	int H = task->camera->screenHeight;
	int rowStart = task->row;
	int rowEnd = task->row + task->rowCount;
	int maxRow = H;

	for (int r = rowStart; r < rowEnd && r < maxRow; r++) {
		SSRProcessRow(task->camera, r);
	}
}

