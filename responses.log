------------------------------------------------------------
void poolAdd(ThreadPool *p, task_fn fn, void *arg)
{
    pthread_mutex_lock(&p->lock);
    Task *q = p->queue;
    int tail = p->tail;
    int new_tail = (tail + 1) % p->capacity;
    q[tail] = (Task){ fn, arg };
    p->tail = new_tail;
    p->count++;
    p->pending++;
    pthread_cond_signal(&p->work_cond);
    pthread_mutex_unlock(&p->lock);
}

============================================================
step=259  func=poolWait  reward=0.1729
------------------------------------------------------------
void poolWait(ThreadPool *p)
{
    pthread_mutex_lock(&p->lock);
    while (p->pending > 0)
        pthread_cond_wait(&p->done_cond, &p->lock);
    pthread_mutex_unlock(&p->lock);
}

============================================================
step=260  func=poolDestroy  reward=0.1114
------------------------------------------------------------
void poolDestroy(ThreadPool *p)
{
    pthread_mutex_lock(&p->lock);
    p->stop = 1;
    pthread_cond_broadcast(&p->work_cond);
    pthread_mutex_unlock(&p->lock);

    for (int i = 0; i < p->nthreads; i++)
        pthread_join(p->threads[i], NULL);

    pthread_mutex_destroy(&p->lock);
    pthread_cond_destroy(&p->work_cond);
    pthread_cond_destroy(&p->done_cond);

    free(p->queue);
    free(p->threads);
    free(p);
}

