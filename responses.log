step=850  func=SSRRowTask  reward=-0.0071
------------------------------------------------------------
static void SSRRowTask(void *arg)
{
	SSRTask *task = arg;
	int row = task->row;
	int rowCount = task->rowCount;
	Camera *camera = task->camera;
	int W = camera->screenWidth;
	int H = camera->screenHeight;

	for (int r = row; r < row + rowCount && r < H; r++) {
		SSRProcessRow(camera, r);
	}
}

