------------------------------------------------------------
void drawTileColor(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y, uint32 color)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}
	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	int srcStride = tile.width;
	int dstStride = dstWidth;

	// Hoist invariants, unroll inner loop for better cache locality
	for (int row = 0; row < copyH; row++) {
		uint32 *dstLine = dst + (y + row) * dstStride;
		const uint32 *srcLine = tile.pixels + (srcY + row) * srcStride;

		for (int col = 0; col < copyW; col++) {
			uint32 src = srcLine[col + srcX];
			if (src != 0x00000000)
				dstLine[col + x] = color;
		}
	}
}

