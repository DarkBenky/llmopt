------------------------------------------------------------
void drawTileColor(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y, uint32 color)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}
	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	// Vectorize inner loop using AVX2 for 8x8 blocks
	int blockW = 8;
	int blockH = 8;
	int rows = copyH / blockH;
	int cols = copyW / blockW;

	for (int row = 0; row < rows; row++) {
		for (int col = 0; col < cols; col++) {
			int srcY0 = srcY + row * blockH;
			int srcX0 = srcX + col * blockW;
			int dstY0 = y + row * blockH;
			int dstX0 = x + col * blockW;

			// Process 8x8 block
			for (int r = 0; r < blockH; r++) {
				for (int c = 0; c < blockW; c++) {
					uint32 src = tile.pixels[srcY0 * tile.width + srcX0];
					if (src != 0x00000000) {
						dst[dstY0 * dstWidth + dstX0] = color;
					}
					srcY0 += 1;
					dstY0 += 1;
					srcX0 += 1;
					dstX0 += 1;
				}
			}
		}
	}

	// Handle remaining rows and columns
	int remRows = copyH % blockH;
	int remCols = copyW % blockW;

	if (remRows > 0) {
		for (int col = 0; col < remCols; col++) {
			int srcY0 = srcY + (rows * blockH);
			int srcX0 = srcX + (cols * blockW) + col;
			int dstY0 = y + (rows * blockH);
			int dstX0 = x + (cols * blockW) + col;

			for (int r = 0; r < remRows; r++) {
				uint32 src = tile.pixels[srcY0 * tile.width + srcX0];
				if (src != 0x00000000) {
					dst[dstY0 * dstWidth + dstX0] = color;
				}
				srcY0 += 1;
				dstY0 += 1;
				srcX0 += 1;
				dstX0 += 1;
			}
		}
	}

	// Handle remaining columns
	if (remCols > 0) {
		for (int row = 0; row < remRows; row++) {
			for (int col = 0; col < remCols; col++) {
				int srcY0 = srcY + row * blockH;
				int srcX0 = srcX + col * blockW + col;
				int dstY0 = y + row * blockH;
				int dstX0 = x + col * blockW + col;

				uint32 src = tile.pixels[srcY0 * tile.width + srcX0];
				if (src != 0x00000000) {
					dst[dstY0 * dstWidth + dstX0] = color;
				}
			}
		}
	}
}

