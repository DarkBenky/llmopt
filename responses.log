step=761  func=BlurBuffer  reward=-0.0671
------------------------------------------------------------
void BlurBuffer(float *src, float *temp, int width, int height, int radius)
{
	if (radius <= 0) return;

	int hasShadow = 0;
	for (int i = 0; i < width * height; i++) {
		if (src[i] < 1.0f) {
			hasShadow = 1;
			break;
		}
	}
	if (!hasShadow) return;

	float invSize = 1.0f / (2 * radius + 1);

	int total = width * height;
	int stride = width;

	// SIMD-optimized horizontal blur
	for (int y = 0; y < height; y++) {
		int rowStart = y * stride;

		int rowHasShadow = 0;
		for (int x = 0; x < width; x++) {
			if (src[rowStart + x] < 1.0f) {
				rowHasShadow = 1;
				break;
			}
		}
		if (!rowHasShadow) {
			for (int x = 0; x < width; x++)
				temp[rowStart + x] = 1.0f;
			continue;
		}

		// Vectorize the horizontal convolution
		int radiusX = radius;
		int radiusY = radius;
		float sum = 0.0f;

		// Initialize with first radius elements
		for (int x = 0; x < radiusX; x++) {
			sum += src[rowStart + x];
		}

		// SIMD vectorization for the remaining loop
		int simd_width = 4; // 4 floats per 128-bit register
		int simd_count = width / simd_width;
		int remainder = width % simd_width;

		// Process in chunks of 4
		for (int x = 0; x < simd_count; x++) {
			int start = x * simd_width;
			int end = start + simd_width;

			// Load 4 values
			__m128 sum_vec = _mm_setzero_ps();
			for (int j = 0; j < simd_width; j++) {
				sum_vec = _mm_add_ps(sum_vec, _mm_set1_ps(src[rowStart + start + j]));
			}

			// Process each element in the chunk
			for (int j = 0; j < simd_width; j++) {
				int idx = start + j;
				int right = idx + radius;
				int left = idx - radius - 1;

				if (right < width) {
					sum_vec = _mm_add_ps(sum_vec, _mm_set1_ps(src[rowStart + right]));
				}
				if (left >= 0) {
					sum_vec = _mm_sub_ps(sum_vec, _mm_set1_ps(src[rowStart + left]));
				}

				// Store result
				temp[rowStart + idx] = sum_vec[0] * invSize;
			}
		}

		// Handle remainder
		for (int x = simd_count * simd_width; x < width; x++) {
			int right = x + radius;
			int left = x - radius - 1;

			if (right < width) sum += src[rowStart + right];
			if (left >= 0) sum -= src[rowStart + left];

			temp[rowStart + x] = sum * invSize;
		}

		// Update sum for vertical pass
		sum = 0.0f;
		for (int x = 0; x < radiusX; x++) {
			sum += src[rowStart + x];
		}

		// Process vertical blur
		for (int y = 0; y < height; y++) {
			int colStart = y * stride;

			int colHasShadow = 0;
			for (int x = 0; x < width; x++) {
				if (temp[colStart + x] < 1.0f) {
					colHasShadow = 1;
					break;
				}
			}
			if (!colHasShadow) {
				for (int x = 0; x < width; x++)
					src[colStart + x] = 1.0f;
				continue;
			}

			// Process vertical convolution
			for (int x = 0; x < width; x++) {
				int bottom = y + radius;
				int top = y - radius - 1;

				if (bottom < height) sum += temp[bottom * stride + x];
				if (top >= 0) sum -= temp[top * stride + x];

				src[y * stride + x] = sum * invSize;
			}
		}
	}
}

