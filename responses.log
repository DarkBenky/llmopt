static inline float3 PositionToRayDir(float3 from, float3 to)
{
	float3 diff = { to.x - from.x, to.y - from.y, to.z - from.z };
	float len = Float3_Length(diff);
	if (len > 0.0f) {
		float invLen = 1.0f / len;
		return (float3){ diff.x * invLen, diff.y * invLen, diff.z * invLen };
	}
	return diff;
}

