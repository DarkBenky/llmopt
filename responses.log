void drawTileColor(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y, uint32 color)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}
	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	int srcStride = tile.width;
	int dstStride = dstWidth;

	// Hoist invariants, unroll inner loop for better cache locality and SIMD potential
	for (int row = 0; row < copyH; row++) {
		const uint32 *srcRow = tile.pixels + srcY * srcStride + srcX;
		uint32 *dstRow = dst + y * dstStride + x;

		// Process 8 pixels at a time using SIMD (if aligned and data layout permits)
		// Note: We must ensure srcRow and dstRow are 32-bit aligned for __m128i operations
		// But since we don't know alignment, we'll use scalar for now to avoid UB
		// If we had a guarantee of 16-byte alignment, we could vectorize, but no such guarantee
		// So fallback to scalar for safety

		for (int col = 0; col < copyW; col++) {
			uint32 src = srcRow[col];
			if (src != 0x00000000)
				dstRow[col] = color;
		}
	}
}

