void Object_SetColor(Object *obj, MaterialLib *lib, float3 color)
{
	int count = obj->triangleCount;
	if (count == 0) return;
	Material *entries = lib->entries;
	int capacity = lib->capacity;
	int *materialIds = obj->materialIds;
	int i;
	for (i = 0; i < count; i++) {
		int idx = materialIds[i];
		if (idx < 0 || idx >= capacity) continue;
		entries[idx].color = color;
	}
}

