step=15  func=ComputeCentroid  reward=-0.2629
------------------------------------------------------------
float3 ComputeCentroid(const Object *obj, const int *ObjectIdx, int ObjectsCount)
{
    float3 centroid = {0, 0, 0};
    #pragma omp parallel for
    for (int i = 0; i < ObjectsCount; i++) {
        int idx = ObjectIdx[i];
        int triangleCount = obj[idx].triangleCount;
        for (int j = 0; j < triangleCount; j++) {
            float3 v1 = obj[idx].v1[j];
            float3 v2 = obj[idx].v2[j];
            float3 v3 = obj[idx].v3[j];
            centroid.x += v1.x + v2.x + v3.x;
            centroid.y += v1.y + v2.y + v3.y;
            centroid.z += v1.z + v2.z + v3.z;
        }
    }
    if (ObjectsCount > 0) {
        float invCount = 1.0f / ObjectsCount;
        centroid.x *= invCount;
        centroid.y *= invCount;
        centroid.z *= invCount;
    }
    return centroid;
}

