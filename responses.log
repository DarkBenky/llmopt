step=726  func=InverseRotateXYZ  reward=-0.0123
------------------------------------------------------------
static inline float3 InverseRotateXYZ(float3 v, float3 rotation)
{
	float c1 = cosf(rotation.x);
	float s1 = sinf(rotation.x);
	float c2 = cosf(rotation.y);
	float s2 = sinf(rotation.y);
	float c3 = cosf(rotation.z);
	float s3 = sinf(rotation.z);
	
	float x = v.x;
	float y = v.y;
	float z = v.z;
	
	// Apply RotateX(-rotation.x)
	x = x;
	y = y * c1 - z * s1;
	z = y * s1 + z * c1;
	
	// Apply RotateY(-rotation.y)
	x = x * c2 + z * s2;
	y = y;
	z = -x * s2 + z * c2;
	
	// Apply RotateZ(-rotation.z)
	x = x * c3 - y * s3;
	y = x * s3 + y * c3;
	z = z;
	
	return (float3){x, y, z};
}

