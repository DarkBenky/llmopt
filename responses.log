------------------------------------------------------------
static inline void BoxBlur3x3(float3 *src, float3 *tmp, float3 *dst, int width, int height)
{
    const int simd_width = 4;
    const int simd_bytes = 16;
    const int simd_mask = 0x7;

    for (int y = 0; y < height; y++) {
        const float3 *row = src + y * width;
        float3 *trow = tmp + y * width;
        float3 *trow_end = trow + width;

        // First and last column: scalar
        trow[0] = (float3){(row[0].x + row[1].x) * 0.5f,
                           (row[0].y + row[1].y) * 0.5f,
                           (row[0].z + row[1].z) * 0.5f};
        trow[width - 1] = (float3){(row[width - 2].x + row[width - 1].x) * 0.5f,
                                   (row[width - 2].y + row[width - 1].y) * 0.5f,
                                   (row[width - 2].z + row[width - 1].z) * 0.5f};

        // Middle columns: vectorize with 4x4 blocks
        for (int x = 1; x < width - 1; x += simd_width) {
            int end = x + simd_width;
            if (end > width) end = width;

            // Load 4 consecutive elements
            __m128i a0 = _mm_loadu_si128((const __m128i*)(row + x - 1));
            __m128i a1 = _mm_loadu_si128((const __m128i*)(row + x));
            __m128i a2 = _mm_loadu_si128((const __m128i*)(row + x + 1));
            __m128i b0 = _mm_loadu_si128((const __m128i*)(row + x - 1 + 4));
            __m128i b1 = _mm_loadu_si128((const __m128i*)(row + x + 4));
            __m128i b2 = _mm_loadu_si128((const __m128i*)(row + x + 1 + 4));

            // Compute sum for 4x4 blocks
            __m128i sum0 = _mm_add_epi32(_mm_add_epi32(a0, a1), a2);
            __m128i sum1 = _mm_add_epi32(_mm_add_epi32(b0, b1), b2);
            __m128i sum2 = _mm_add_epi32(_mm_add_epi32(a0, a1), a2);
            __m128i sum3 = _mm_add_epi32(_mm_add_epi32(b0, b1), b2);

            // Scale by 1/3
            __m128i scale = _mm_set1_ps(1.0f / 3.0f);
            __m128i scaled0 = _mm_mul_ps(_mm_castsi128_ps(sum0), scale);
            __m128i scaled1 = _mm_mul_ps(_mm_castsi128_ps(sum1), scale);
            __m128i scaled2 = _mm_mul_ps(_mm_castsi128_ps(sum2), scale);
            __m128i scaled3 = _mm_mul_ps(_mm_castsi128_ps(sum3), scale);

            // Store back
            _mm_storeu_si128((void*)(trow + x), _mm_castps_si128(scaled0));
            _mm_storeu_si128((void*)(trow + x + 1), _mm_castps_si128(scaled1));
            _mm_storeu_si128((void*)(trow + x + 2), _mm_castps_si128(scaled2));
            _mm_storeu_si128((void*)(trow + x + 3), _mm_castps_si128(scaled3));
        }
    }

    // Vertical blur
    for (int x = 0; x < width; x++) {
        dst[x] = (float3){(tmp[x].x + tmp[width + x].x) * 0.5f,
                          (tmp[x].y + tmp[width + x].y) * 0.5f,
                          (tmp[x].z + tmp[width + x].z) * 0.5f};
    }

    // Middle rows: vertical blur
    for (int y = 1; y < height - 1; y++) {
        const float3 *ta = tmp + (y - 1) * width;
        const float3 *tb = tmp + y * width;
        const float3 *tc = tmp + (y + 1) * width;
        float3 *drow = dst + y * width;

        for (int x = 0; x < width; x++) {
            drow[x] = (float3){(ta[x].x + tb[x].x + tc[x].x) * (1.0f / 3.0f),
                               (ta[x].y + tb[x].y + tc[x].y) * (1.0f / 3.0f),
                               (ta[x].z + tb[x].z + tc[x].z) * (1.0f / 3.0f)};
        }
    }

    // Last row
    const float3 *ta = tmp + (height - 2) * width;
    const float3 *tb = tmp + (height - 1) * width;
    float3 *drow = dst + (height - 1) * width;
    for (int x = 0; x < width; x++) {
        drow[x] = (float3){(ta[x].x + tb[x].x) * 0.5f,
                           (ta[x].y + tb[x].y) * 0.5f,
                           (ta[x].z + tb[x].z) * 0.5f};
    }
}

