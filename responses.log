static float3 RandomObjectHitRay(const Object *object, float3 rayOrigin, float seed, float3 *outHitPos)
{
	int triIdx = (int)(RandomFloat(seed) * object->triangleCount) % object->triangleCount;

	float3 v0 = object->v1[triIdx];
	float3 v1 = object->v2[triIdx];
	float3 v2 = object->v3[triIdx];

	float r1 = RandomFloat(seed + 1.0f);
	float r2 = RandomFloat(seed + 2.0f);
	if (r1 + r2 > 1.0f) {
		r1 = 1.0f - r1;
		r2 = 1.0f - r2;
	}
	float r0 = 1.0f - r1 - r2;

	// Vectorize the barycentric interpolation
	__m128 v0x = _mm_load_ps(&v0.x);
	__m128 v0y = _mm_load_ps(&v0.y);
	__m128 v0z = _mm_load_ps(&v0.z);
	__m128 v1x = _mm_load_ps(&v1.x);
	__m128 v1y = _mm_load_ps(&v1.y);
	__m128 v1z = _mm_load_ps(&v1.z);
	__m128 v2x = _mm_load_ps(&v2.x);
	__m128 v2y = _mm_load_ps(&v2.y);
	__m128 v2z = _mm_load_ps(&v2.z);

	__m128 r0x = _mm_set1_ps(r0);
	__m128 r1x = _mm_set1_ps(r1);
	__m128 r2x = _mm_set1_ps(r2);

	__m128 localPosx = _mm_add_ps(
		_mm_mul_ps(r0x, v0x),
		_mm_add_ps(
			_mm_mul_ps(r1x, v1x),
			_mm_mul_ps(r2x, v2x)
		)
	);

	__m128 localPosy = _mm_add_ps(
		_mm_mul_ps(r0x, v0y),
		_mm_add_ps(
			_mm_mul_ps(r1x, v1y),
			_mm_mul_ps(r2x, v2y)
		)
	);

	__m128 localPosz = _mm_add_ps(
		_mm_mul_ps(r0x, v0z),
		_mm_add_ps(
			_mm_mul_ps(r1x, v1z),
			_mm_mul_ps(r2x, v2z)
		)
	);

	float3 localPos = {
		_mm_cvtss_f32(localPosx),
		_mm_cvtss_f32(localPosy),
		_mm_cvtss_f32(localPosz)
	};

	// Vectorize rotation
	float3 rot = object->rotation;
	float3 worldPos = localPos;
	worldPos.x = localPos.x * object->scale.x + object->position.x;
	worldPos.y = localPos.y * object->scale.y + object->position.y;
	worldPos.z = localPos.z * object->scale.z + object->position.z;

	// Vectorize normalization
	float3 v = Float3_Sub(worldPos, rayOrigin);
	float len = Float3_Length(v);
	if (len > 0.0f) {
		float invLen = 1.0f / len;
		return (float3){
			v.x * invLen,
			v.y * invLen,
			v.z * invLen
		};
	}
	return v;
}

