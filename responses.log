{
	float e = fmaxf(fr, fmaxf(fg, fb)) - 1.0f;
	if (e > 0.0f) {
		fr = fminf(fr + e, 1.0f);
		fg = fminf(fg + e, 1.0f);
		fb = fminf(fb + e, 1.0f);
	}
	return (float3){fr, fg, fb};
