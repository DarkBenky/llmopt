step=7  func=Object_SetColor  reward=-0.2656
------------------------------------------------------------
void Object_SetColor(Object *obj, MaterialLib *lib, float3 color)
{
    int triangleCount = obj->triangleCount;
    int *materialIds = obj->materialIds;
    Material *entries = lib->entries;
    int count = lib->count;

    // Vectorize by processing 4 triangles at a time
    for (int i = 0; i < triangleCount; i += 4) {
        int j = i;
        if (j >= triangleCount) break;

        // Load 4 material indices
        int idx0 = materialIds[j];
        int idx1 = materialIds[j + 1];
        int idx2 = materialIds[j + 2];
        int idx3 = materialIds[j + 3];
        if (j + 3 >= triangleCount) {
            // Handle last partial batch
            int remaining = triangleCount - j;
            for (int k = 0; k < remaining; k++) {
                entries[materialIds[j + k]].color = color;
            }
        } else {
            // Vectorize 4 assignments
            entries[idx0].color = color;
            entries[idx1].color = color;
            entries[idx2].color = color;
            entries[idx3].color = color;
        }
    }
}

