void DitherOrderedPostProcess(Camera *camera, int frame)
{
	if (!camera) return;
	int width = camera->screenWidth;
	int height = camera->screenHeight;

	static const float bayer[4][4] = {
		{0.0f / 16.0f, 8.0f / 16.0f, 2.0f / 16.0f, 10.0f / 16.0f},
		{12.0f / 16.0f, 4.0f / 16.0f, 14.0f / 16.0f, 6.0f / 16.0f},
		{3.0f / 16.0f, 11.0f / 16.0f, 1.0f / 16.0f, 9.0f / 16.0f},
		{15.0f / 16.0f, 7.0f / 16.0f, 13.0f / 16.0f, 5.0f / 16.0f},
	};

	// Vectorize inner loop with 4x4 tile
	int tile_width = 4;
	int tile_height = 4;
	for (int y = 0; y < height; y += tile_height) {
		for (int x = 0; x < width; x += tile_width) {
			int y0 = y, x0 = x;
			for (int dy = 0; dy < tile_height; dy++) {
				for (int dx = 0; dx < tile_width; dx++) {
					int idx = (y0 + dy) * width + (x0 + dx);
					Color c = camera->framebuffer[idx];
					int r = (c >> 16) & 0xFF;
					int g = (c >> 8) & 0xFF;
					int b = c & 0xFF;

					int by = (y0 + frame) & 3;
					int bx = (x0 + dx) & 3;
					float t = bayer[by][bx];
					int bias = (int)(t * 48.0f) - 24; 

					r += bias;
					if (r < 0) r = 0; else if (r > 255) r = 255;
					g += bias;
					if (g < 0) g = 0; else if (g > 255) g = 255;
					b += bias;
					if (b < 0) b = 0; else if (b > 255) b = 255;

					camera->framebuffer[idx] = 0xFF000000u | ((uint32)r << 16) | ((uint32)g << 8) | (uint32)b;
				}
			}
		}
	}
}

