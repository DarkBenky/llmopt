step=63  func=InverseRotateXYZ  reward=0.0331
------------------------------------------------------------
static inline float3 InverseRotateXYZ(float3 v, float3 rotation)
{
	float c_x = cosf(rotation.x);
	float s_x = sinf(rotation.x);
	float c_y = cosf(rotation.y);
	float s_y = sinf(rotation.y);
	float c_z = cosf(rotation.z);
	float s_z = sinf(rotation.z);

	v.x = v.x * c_y * c_z + v.y * s_y * s_z + v.z * s_y * c_z;
	v.y = v.x * c_y * s_z + v.y * c_y * c_z + v.z * c_y * s_z;
	v.z = v.x * s_y * c_z + v.y * s_y * c_z + v.z * s_y * s_z;

	return v;
}

