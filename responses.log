{
	__asm__ volatile (
		"cmpl %1, %0\n\t"
		"movl %0, %2\n\t"
		"cmovl %1, %0\n\t"
		: "=r"(a), "=m"(b), "=r"(a)
		: "r"(a), "r"(b)
		: "memory"
	);
