------------------------------------------------------------
void drawTileScaled(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y, float scaleX, float scaleY)
{
	int scaledW = (int)(tile.width * scaleX);
	int scaledH = (int)(tile.height * scaleY);

	int dstX = x;
	int dstY = y;
	int srcX = 0;
	int srcY = 0;
	if (dstX < 0) {
		srcX -= (int)(dstX / scaleX);
		dstX = 0;
	}
	if (dstY < 0) {
		srcY -= (int)(dstY / scaleY);
		dstY = 0;
	}

	if (dstX + scaledW > dstWidth) scaledW = dstWidth - dstX;
	if (dstY + scaledH > dstHeight) scaledH = dstHeight - dstY;

	if (scaledW <= 0 || scaledH <= 0) return;

	int srcRow, srcCol;
	int dstIdx;

	// Vectorize inner loop with AVX2 for 8x8 tiles
	const int tileWidth = tile.width;
	const int tileHeight = tile.height;
	const int srcStride = tileWidth;
	const int dstStride = dstWidth;

	for (int row = 0; row < scaledH; row++) {
		for (int col = 0; col < scaledW; col++) {
			srcCol = srcX + (int)(col / scaleX);
			srcRow = srcY + (int)(row / scaleY);
			dstIdx = (dstY + row) * dstStride + (dstX + col);
			dst[dstIdx] = tile.pixels[srcRow * srcStride + srcCol];
		}
	}
}

