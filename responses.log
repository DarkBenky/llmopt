step=27  func=drawTileColorScaled  reward=-0.0959
------------------------------------------------------------
void drawTileColorScaled(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y, float scaleX, float scaleY, uint32 color)
{
	int scaledW = (int)(tile.width * scaleX);
	int scaledH = (int)(tile.height * scaleY);

	int dstX = x, dstY = y;
	int srcX = 0, srcY = 0;
	if (dstX < 0) {
		srcX -= (int)(dstX / scaleX);
		dstX = 0;
	}
	if (dstY < 0) {
		srcY -= (int)(dstY / scaleY);
		dstY = 0;
	}
	if (dstX + scaledW > dstWidth) scaledW = dstWidth - dstX;
	if (dstY + scaledH > dstHeight) scaledH = dstHeight - dstY;

	if (scaledW <= 0 || scaledH <= 0) return;

	const uint32 *pixels = tile.pixels;
	int tileWidth = (int)tile.width;
	int tileHeight = (int)tile.height;

	int srcRowStride = tileWidth;
	int dstStride = dstWidth;

	// Vectorize inner loop with 4x4 tiles
	int tileW = scaledW;
	int tileH = scaledH;
	int tileSize = 16; // 4x4 = 16 pixels

	for (int row = 0; row < tileH; row += 4) {
		for (int col = 0; col < tileW; col += 4) {
			int srcRow = srcY + row;
			int srcCol = srcX + col;
			int dstRow = dstY + row;
			int dstCol = dstX + col;

			// Process 4x4 block
			for (int r = 0; r < 4; r++) {
				int srcYr = srcRow + r;
				for (int c = 0; c < 4; c++) {
					int srcXc = srcCol + c;
					uint32 src = pixels[srcYr * tileWidth + srcXc];
					if (src != 0x00000000) {
						int dstIdx = (dstRow + r) * dstStride + (dstCol + c);
						dst[dstIdx] = color;
					}
				}
			}
		}
	}

	// If remaining pixels < 4, handle them manually
	if (tileW < 4 || tileH < 4) {
		for (int row = 0; row < tileH; row++) {
			for (int col = 0; col < tileW; col++) {
				int srcRow = srcY + row;
				int srcCol = srcX + col;
				int dstRow = dstY + row;
				int dstCol = dstX + col;

				uint32 src = pixels[srcRow * tileWidth + srcCol];
				if (src != 0x00000000) {
					int dstIdx = (dstRow) * dstStride + (dstCol);
					dst[dstIdx] = color;
				}
			}
		}
	}
}

