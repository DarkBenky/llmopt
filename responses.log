Color IntersectBBoxColor(const Object *objects, int objectCount, float3 rayOrigin, float3 rayDir)
{
    __m128 originX = _mm_set_ps(0.0f, 0.0f, 0.0f, rayOrigin.x);
    __m128 originY = _mm_set_ps(0.0f, 0.0f, 0.0f, rayOrigin.y);
    __m128 originZ = _mm_set_ps(0.0f, 0.0f, 0.0f, rayOrigin.z);
    __m128 dirX = _mm_set_ps(0.0f, 0.0f, 0.0f, rayDir.x);
    __m128 dirY = _mm_set_ps(0.0f, 0.0f, 0.0f, rayDir.y);
    __m128 dirZ = _mm_set_ps(0.0f, 0.0f, 0.0f, rayDir.z);

    float closestT = FLT_MAX;
    Color hitColor = 0;

    for (int i = 0; i < objectCount; i++) {
        float tMin, tMax;
        RayBoxItersect(&objects[i], rayOrigin, rayDir, &tMin, &tMax);
        if (tMin < tMax && tMin < closestT) {
            closestT = tMin;
            hitColor = objects[i]._temp;
        }
    }
    return hitColor;
}

