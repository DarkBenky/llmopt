step=5  func=rayAABB_inv  reward=-1.0000
------------------------------------------------------------
static inline float rayAABB_inv(float3 bias, float3 invRd, const float *mn, const float *mx)
{
    __m128 m0 = _mm_load_ps(&mn[0]);
    __m128 m1 = _mm_load_ps(&mn[1]);
    __m128 m2 = _mm_load_ps(&mn[2]);
    __m128 x0 = _mm_load_ps(&mx[0]);
    __m128 x1 = _mm_load_ps(&mx[1]);
    __m128 x2 = _mm_load_ps(&mx[2]);
    __m128 b0 = _mm_load_ps(&bias.x);
    __m128 b1 = _mm_load_ps(&bias.y);
    __m128 b2 = _mm_load_ps(&bias.z);
    __m128 invRd0 = _mm_load_ps(&invRd.x);
    __m128 invRd1 = _mm_load_ps(&invRd.y);
    __m128 invRd2 = _mm_load_ps(&invRd.z);

    __m128 tx0 = _mm_mul_ps(m0, invRd0);
    __m128 tx1 = _mm_mul_ps(x0, invRd0);
    __m128 ty0 = _mm_mul_ps(m1, invRd1);
    __m128 ty1 = _mm_mul_ps(x1, invRd1);
    __m128 tz0 = _mm_mul_ps(m2, invRd2);
    __m128 tz1 = _mm_mul_ps(x2, invRd2);

    __m128 tx0b = _mm_sub_ps(tx0, b0);
    __m128 tx1b = _mm_sub_ps(tx1, b0);
    __m128 ty0b = _mm_sub_ps(ty0, b1);
    __m128 ty1b = _mm_sub_ps(ty1, b1);
    __m128 tz0b = _mm_sub_ps(tz0, b2);
    __m128 tz1b = _mm_sub_ps(tz1, b2);

    __m128 tmin0 = _mm_min_ps(tx0b, tx1b);
    __m128 tmin1 = _mm_min_ps(ty0b, ty1b);
    __m128 tmin2 = _mm_min_ps(tz0b, tz1b);
    __m128 tmin = _mm_max_ps(_mm_max_ps(tmin0, tmin1), tmin2);

    __m128 tmax0 = _mm_max_ps(tx0b, tx1b);
    __m128 tmax1 = _mm_max_ps(ty0b, ty1b);
    __m128 tmax2 = _mm_max_ps(tz0b, tz1b);
    __m128 tmax = _mm_min_ps(_mm_min_ps(tmax0, tmax1), tmax2);

    __m128 tminf = _mm_set_ps(FLT_MAX, FLT_MAX, FLT_MAX, FLT_MAX);
    __m128 tmaxf = _mm_set_ps(FLT_MAX, FLT_MAX, FLT_MAX, FLT_MAX);
    __m128 tmin_cmp = _mm_cmplt_ps(tmax, tmin);
    __m128 tmin_cmpf = _mm_cmplt_ps(tmaxf, tminf);
    __m128 tmin_mask = _mm_and_ps(tmin_cmp, _mm_set1_ps(1.0f));
    __m128 tmax_mask = _mm_and_ps(tmin_cmpf, _mm_set1_ps(1.0f));

    __m128 tmin_final = _mm_and_ps(tmin, tmin_mask);
    __m128 tmax_final = _mm_and_ps(tmax, tmax_mask);

    __m128 zero = _mm_set1_ps(0.0f);
    __m128 tmin_finalf = _mm_and_ps(tmin_final, zero);
    __m128 tmax_finalf = _mm_and_ps(tmax_final, zero);

    if (_mm_movemask_ps(tmin_mask) == 0) {
        return FLT_MAX;
    }

    return _mm_cvtss_f32(tmin_final);
}

