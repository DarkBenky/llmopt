	Color *fb = camera->framebuffer;
	int4 *accum = camera->accumulationBuffer;
	uint32 *buf = camera->framebuffer;
	int4 *acc = camera->accumulationBuffer;
	int stride = width;

	int32_t red = 0, green = 0, blue = 0;
	int32_t count = 0;

	for (int row = 0; row < height; row++) {
		for (int col = 0; col < width; col++) {
			int32_t r = 0, g = 0, b = 0;
			int32_t cnt = 0;
			for (int dy = -1; dy <= 1; dy++) {
				for (int dx = -1; dx <= 1; dx++) {
					int x = col + dx;
					int y = row + dy;
					if (x >= 0 && x < width && y >= 0 && y < height) {
						Color c = fb[y * stride + x];
						int4 rgb = UnpackColorInt(c);
						r += rgb.x;
						g += rgb.y;
						b += rgb.z;
						cnt++;
					}
				}
			}
			fb[row * stride + col] = PackColorSafe((float)r / cnt / 255.0f, (float)g / cnt / 255.0f, (float)b / cnt / 255.0f);
