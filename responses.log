step=80  func=RotateXYZ  reward=-1.0000
------------------------------------------------------------
static inline float3 RotateXYZ(float3 v, float3 rotation)
{
	float c1 = cosf(rotation.x);
	float s1 = sinf(rotation.x);
	float c2 = cosf(rotation.y);
	float s2 = sinf(rotation.y);
	float c3 = cosf(rotation.z);
	float s3 = sinf(rotation.z);

	float x = v.x;
	float y = v.y;
	float z = v.z;

	float temp1 = y * c1 - z * s1;
	float temp2 = y * s1 + z * c1;
	float temp3 = x * c1 + z * s1;
	float temp4 = -x * s1 + z * c1;

	x = temp3;
	y = temp4;
	z = temp1;

	x = x * c2 + z * s2;
	z = x * s2 - z * c2;
	x = x * c3 - y * s3;
	y = x * s3 + y * c3;

	return (float3){
		x,
		y,
		z};
}

