static inline void BoxBlur3x3(float3 *src, float3 *tmp, float3 *dst, int width, int height)
{
    const int simd_width = 4;
    const int simd_loop = width / simd_width;
    const int simd_remain = width % simd_width;
    
    for (int y = 0; y < height; y++) {
        const float3 *row = src + y * width;
        float3 *trow = tmp + y * width;
        float3 *trow_end = trow + width;
        
        // Process first 2 columns with 1/2 weight
        trow[0] = (float3){(row[0].x + row[1].x) * 0.5f,
                           (row[0].y + row[1].y) * 0.5f,
                           (row[0].z + row[1].z) * 0.5f};
        trow[1] = (float3){(row[1].x + row[2].x) * 0.5f,
                           (row[1].y + row[2].y) * 0.5f,
                           (row[1].z + row[2].z) * 0.5f};
        
        // Process middle columns using 1/3 weight
        for (int x = 2; x < width - 2; x += simd_width) {
            int end = x + simd_width;
            if (end > width) end = width;
            
            __m128i a = _mm_setzero_si128();
            __m128i b = _mm_setzero_si128();
            __m128i c = _mm_setzero_si128();
            
            for (int i = 0; i < simd_width; i++) {
                int idx = x + i;
                if (idx < width) {
                    a = _mm_add_ps(_mm_set1_ps(1.0f / 3.0f), _mm_load_ps(&row[idx].x));
                    b = _mm_add_ps(_mm_set1_ps(1.0f / 3.0f), _mm_load_ps(&row[idx].y));
                    c = _mm_add_ps(_mm_set1_ps(1.0f / 3.0f), _mm_load_ps(&row[idx].z));
                }
            }
            
            for (int i = 0; i < simd_width; i++) {
                int idx = x + i;
                if (idx < width) {
                    trow[idx] = (float3){(row[idx].x + row[idx + 1].x + row[idx + 2].x) * (1.0f / 3.0f),
                                         (row[idx].y + row[idx + 1].y + row[idx + 2].y) * (1.0f / 3.0f),
                                         (row[idx].z + row[idx + 1].z + row[idx + 2].z) * (1.0f / 3.0f)};
                }
            }
        }
        
        // Process last 2 columns with 1/2 weight
        trow[width - 2] = (float3){(row[width - 3].x + row[width - 2].x) * 0.5f,
                                   (row[width - 3].y + row[width - 2].y) * 0.5f,
                                   (row[width - 3].z + row[width - 2].z) * 0.5f};
        trow[width - 1] = (float3){(row[width - 2].x + row[width - 1].x) * 0.5f,
                                   (row[width - 2].y + row[width - 1].y) * 0.5f,
                                   (row[width - 2].z + row[width - 1].z) * 0.5f};
    }
    
    // Vertical blur
    for (int x = 0; x < width; x++) {
        dst[x] = (float3){(tmp[x].x + tmp[width + x].x) * 0.5f,
                          (tmp[x].y + tmp[width + x].y) * 0.5f,
                          (tmp[x].z + tmp[width + x].z) * 0.5f};
    }
    
    for (int y = 1; y < height - 1; y++) {
        const float3 *ta = tmp + (y - 1) * width;
        const float3 *tb = tmp + y * width;
        const float3 *tc = tmp + (y + 1) * width;
        float3 *drow = dst + y * width;
        
        for (int x = 0; x < width; x++) {
            drow[x] = (float3){(ta[x].x + tb[x].x + tc[x].x) * (1.0f / 3.0f),
                               (ta[x].y + tb[x].y + tc[x].y) * (1.0f / 3.0f),
                               (ta[x].z + tb[x].z + tc[x].z) * (1.0f / 3.0f)};
        }
    }
    
    const float3 *ta = tmp + (height - 2) * width;
    const float3 *tb = tmp + (height - 1) * width;
    float3 *drow = dst + (height - 1) * width;
    for (int x = 0; x < width; x++) {
        drow[x] = (float3){(ta[x].x + tb[x].x) * 0.5f,
                           (ta[x].y + tb[x].y) * 0.5f,
                           (ta[x].z + tb[x].z) * 0.5f};
    }
}

