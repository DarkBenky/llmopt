static inline float3 ApplyRotMat3(float3 v, RotMat3 m)
{
	float x = v.x, y = v.y, z = v.z;
	float ax = m.m[0][0] * x + m.m[0][1] * y + m.m[0][2] * z;
	float ay = m.m[1][0] * x + m.m[1][1] * y + m.m[1][2] * z;
	float az = m.m[2][0] * x + m.m[2][1] * y + m.m[2][2] * z;
	return (float3){ax, ay, az};
}

