Color PackColor(float r, float g, float b)
{
	uint8 r8 = (uint8)(r * 255.0f);
	uint8 g8 = (uint8)(g * 255.0f);
	uint8 b8 = (uint8)(b * 255.0f);
	return (Color)((r8 << 16) | (g8 << 8) | b8);
