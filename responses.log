step=11  func=RotateXYZ  reward=-0.1397
------------------------------------------------------------
static inline float3 RotateXYZ(float3 v, float3 rotation)
{
	float c1 = cosf(rotation.x);
	float s1 = sinf(rotation.x);
	float c2 = cosf(rotation.y);
	float s2 = sinf(rotation.y);
	float c3 = cosf(rotation.z);
	float s3 = sinf(rotation.z);

	float x = v.x;
	float y = v.y;
	float z = v.z;

	float x1 = x;
	float y1 = y * c1 - z * s1;
	float z1 = y * s1 + z * c1;

	float x2 = x1 * c2 + z1 * s2;
	float y2 = y1;
	float z2 = -x1 * s2 + z1 * c2;

	float x3 = x2 * c3 - y2 * s3;
	float y3 = x2 * s3 + y2 * c3;
	float z3 = z2;

	return (float3){x3, y3, z3};
}

