Color AdjustContrast(Color c, float contrast)
{
	float3 col = UnpackColor(c);
	__m128 vcontrast = _mm_set_ss(contrast);
	__m128 v05 = _mm_set_ss(0.5f);
	__m128 v15 = _mm_set_ss(1.5f);
	__m128 v255 = _mm_set_ss(255.0f);
	__m128 v0 = _mm_setzero_ps();
	
	// Vectorize the per-channel operation: (x - 0.5) * contrast + 0.5
	// Note: We must avoid floating point operations that are not vectorizable
	// because this is a scalar function, but we can still use SIMD if we
	// can vectorize the data (which we can't because it's single value per channel)
	// So we keep it scalar for now, but if we can find a way to vectorize
	// the entire function, we might consider it. But for now, we can't vectorize
	// because it's a scalar function. So we keep it scalar.
	
	float r = (col.x - 0.5f) * contrast + 0.5f;
	float g = (col.y - 0.5f) * contrast + 0.5f;
	float b = (col.z - 0.5f) * contrast + 0.5f;
	return PackColorF((float3){r, g, b, 0.0f});
}

