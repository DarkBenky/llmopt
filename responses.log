bool IntersectAnyBBox(const Object *objects, int objectCount, float3 rayOrigin, float3 rayDir)
{
	for (int i = 0; i < objectCount; i++) {
		float tMin, tMax;
		RayBoxItersect(&objects[i], rayOrigin, rayDir, &tMin, &tMax);
		if (tMin < tMax) {
			return true;
		}
	}
	return false;
}

