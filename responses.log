static inline float3 ApplyRotMat3(float3 v, RotMat3 m)
{
	float x = v.x, y = v.y, z = v.z;
	float a00 = m.m[0][0], a01 = m.m[0][1], a02 = m.m[0][2];
	float a10 = m.m[1][0], a11 = m.m[1][1], a12 = m.m[1][2];
	float a20 = m.m[2][0], a21 = m.m[2][1], a22 = m.m[2][2];
	return (float3){
		a00 * x + a01 * y + a02 * z,
		a10 * x + a11 * y + a12 * z,
		a20 * x + a21 * y + a22 * z
	};
}

