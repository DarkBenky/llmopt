step=3  func=rayAABB  reward=0.0084
------------------------------------------------------------
static float rayAABB(float3 ro, float3 rd, float3 mn, float3 mx)
{
	float tmin = 0.0f, tmax = FLT_MAX;
	const float *o = &ro.x, *d = &rd.x, *bmin = &mn.x, *bmax = &mx.x;
	__m128 t0, t1, tmin_vec, tmax_vec;
	__m128 invD, invD_vec;
	__m128 bmin_vec, bmax_vec, o_vec;
	__m128 zero = _mm_setzero_ps();
	__m128 one = _mm_set1_ps(1.0f);
	__m128 zero_vec = _mm_setzero_ps();
	float invD_val;
	float t0_val, t1_val;
	float tmin_val, tmax_val;
	float tmin_final = tmin, tmax_final = tmax;

	for (int i = 0; i < 3; i++) {
		if (fabsf(d[i]) < 1e-8f) {
			if (o[i] < bmin[i] || o[i] > bmax[i]) return FLT_MAX;
			continue;
		}
		invD_val = 1.0f / d[i];
		t0_val = (bmin[i] - o[i]) * invD_val;
		t1_val = (bmax[i] - o[i]) * invD_val;
		if (t0_val > t1_val) {
			float tmp = t0_val;
			t0_val = t1_val;
			t1_val = tmp;
		}
		tmin_val = MaxF32(tmin, t0_val);
		tmax_val = MinF32(tmax, t1_val);
		if (tmin_val > tmax_val) return FLT_MAX;
		tmin = tmin_val;
		tmax = tmax_val;
	}

	return tmin;
}

