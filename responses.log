Color BlendColors(Color c1, Color c2, float t)
{
	float3 col1 = UnpackColor(c1);
	float3 col2 = UnpackColor(c2);
	float3 blended = {
		col1.x * (1.0f - t) + col2.x * t,
		col1.y * (1.0f - t) + col2.y * t,
		col1.z * (1.0f - t) + col2.z * t};
	return PackColorF(blended);
}

