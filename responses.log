	__m128 s_vec = _mm_set_ps1(s);
	__m128 r_vec = _mm_set_ss(col.x);
	__m128 g_vec = _mm_set_ss(col.y);
	__m128 b_vec = _mm_set_ss(col.z);
	__m128 r_res = _mm_mul_ps(r_vec, s_vec);
	__m128 g_res = _mm_mul_ps(g_vec, s_vec);
	__m128 b_res = _mm_mul_ps(b_vec, s_vec);
	float3 res = (float3){_mm_cvtss_f32(r_res), _mm_cvtss_f32(g_res), _mm_cvtss_f32(b_res)};
	return PackColorF(res);
}

