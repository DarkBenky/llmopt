------------------------------------------------------------
void DitherOrderedPostProcess(Camera *camera, int frame)
{
	if (!camera) return;
	int width = camera->screenWidth;
	int height = camera->screenHeight;

	static const float bayer[4][4] = {
		{0.0f / 16.0f, 8.0f / 16.0f, 2.0f / 16.0f, 10.0f / 16.0f},
		{12.0f / 16.0f, 4.0f / 16.0f, 14.0f / 16.0f, 6.0f / 16.0f},
		{3.0f / 16.0f, 11.0f / 16.0f, 1.0f / 16.0f, 9.0f / 16.0f},
		{15.0f / 16.0f, 7.0f / 16.0f, 13.0f / 16.0f, 5.0f / 16.0f},
	};

	// Vectorize inner loop with SIMD intrinsics
	const int SIMD_WIDTH = 4; // Process 4 pixels per iteration
	const int MAX_PIXELS = width * height;

	// Hoist invariants, unroll loops, use SoA layout for cache-friendliness
	// Convert Color to int32 for SIMD operations
	uint32_t *framebuffer = camera->framebuffer;
	int *framebuffer_ptr = (int*)framebuffer; // cast for easier manipulation

	// Use 4x4 tile for SIMD
	for (int y = 0; y < height; y += SIMD_WIDTH) {
		for (int x = 0; x < width; x += SIMD_WIDTH) {
			int tile_y = y;
			int tile_x = x;

			// Process 4x4 tile
			for (int dy = 0; dy < SIMD_WIDTH; dy++) {
				for (int dx = 0; dx < SIMD_WIDTH; dx++) {
					int idx = tile_y * width + tile_x;
					Color c = framebuffer[idx];
					int r = (c >> 16) & 0xFF;
					int g = (c >> 8) & 0xFF;
					int b = c & 0xFF;

					int y_idx = tile_y + dy;
					int x_idx = tile_x + dx;
					int pixel_idx = y_idx * width + x_idx;

					int bayer_idx = (y_idx + frame) & 3;
					int bayer_x = x_idx & 3;
					float t = bayer[bayer_idx][bayer_x];
					int bias = (int)(t * 48.0f) - 24;

					r += bias;
					if (r < 0) r = 0;
					else if (r > 255) r = 255;

					g += bias;
					if (g < 0) g = 0;
					else if (g > 255) g = 255;

					b += bias;
					if (b < 0) b = 0;
					else if (b > 255) b = 255;

					framebuffer[pixel_idx] = 0xFF000000u | ((uint32)r << 16) | ((uint32)g << 8) | (uint32)b;
				}
			}
		}
	}
}

