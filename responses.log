static inline void DecimateBuffer(float3 *src, float3 *dst, int width, int height, int factor)
{
	int dstWidth = width / factor;
	int dstHeight = height / factor;
	float invSamples = 1.0f / (float)(factor * factor);
	__m128 accumX = _mm_setzero_ps();
	__m128 accumY = _mm_setzero_ps();
	__m128 accumZ = _mm_setzero_ps();
	__m128i accumI = _mm_setzero_si128();

	for (int y = 0; y < dstHeight; y++) {
		for (int x = 0; x < dstWidth; x++) {
			accumX = _mm_setzero_ps();
			accumY = _mm_setzero_ps();
			accumZ = _mm_setzero_ps();
			accumI = _mm_setzero_si128();

			for (int ky = 0; ky < factor; ky++) {
				const float3 *row = src + (y * factor + ky) * width + x * factor;
				for (int kx = 0; kx < factor; kx++) {
					__m128 xval = _mm_load_ps(&row[kx].x);
					__m128 yval = _mm_load_ps(&row[kx].y);
					__m128 zval = _mm_load_ps(&row[kx].z);
					accumX = _mm_add_ps(accumX, xval);
					accumY = _mm_add_ps(accumY, yval);
					accumZ = _mm_add_ps(accumZ, zval);
				}
			}

			__m128 resultX = _mm_mul_ps(accumX, _mm_set_ps1(invSamples));
			__m128 resultY = _mm_mul_ps(accumY, _mm_set_ps1(invSamples));
			__m128 resultZ = _mm_mul_ps(accumZ, _mm_set_ps1(invSamples));

			_mm_store_ps(&dst[y * dstWidth + x].x, resultX);
			_mm_store_ps(&dst[y * dstWidth + x].y, resultY);
			_mm_store_ps(&dst[y * dstWidth + x].z, resultZ);
		}
	}
}

