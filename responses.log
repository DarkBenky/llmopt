------------------------------------------------------------
static inline void BoxBlur3x3(float3 *src, float3 *tmp, float3 *dst, int width, int height)
{
	int i, j;
	for (j = 0; j < height; j++) {
		const float3 *row = src + j * width;
		float3 *trow = tmp + j * width;
		trow[0] = (float3){(row[0].x + row[1].x) * 0.5f,
						   (row[0].y + row[1].y) * 0.5f,
						   (row[0].z + row[1].z) * 0.5f};
		for (i = 1; i < width - 1; i++) {
			trow[i] = (float3){(row[i - 1].x + row[i].x + row[i + 1].x) * (1.0f / 3.0f),
							   (row[i - 1].y + row[i].y + row[i + 1].y) * (1.0f / 3.0f),
							   (row[i - 1].z + row[i].z + row[i + 1].z) * (1.0f / 3.0f)};
		}
		trow[width - 1] = (float3){(row[width - 2].x + row[width - 1].x) * 0.5f,
								   (row[width - 2].y + row[width - 1].y) * 0.5f,
								   (row[width - 2].z + row[width - 1].z) * 0.5f};
	}
	for (i = 0; i < width; i++) {
		dst[i] = (float3){(tmp[i].x + tmp[width + i].x) * 0.5f,
						  (tmp[i].y + tmp[width + i].y) * 0.5f,
						  (tmp[i].z + tmp[width + i].z) * 0.5f};
	}
	for (j = 1; j < height - 1; j++) {
		const float3 *ta = tmp + (j - 1) * width;
		const float3 *tb = tmp + j * width;
		const float3 *tc = tmp + (j + 1) * width;
		float3 *drow = dst + j * width;
		for (i = 0; i < width; i++) {
			drow[i] = (float3){(ta[i].x + tb[i].x + tc[i].x) * (1.0f / 3.0f),
							   (ta[i].y + tb[i].y + tc[i].y) * (1.0f / 3.0f),
							   (ta[i].z + tb[i].z + tc[i].z) * (1.0f / 3.0f)};
		}
	}
	const float3 *ta = tmp + (height - 2) * width;
	const float3 *tb = tmp + (height - 1) * width;
	float3 *drow = dst + (height - 1) * width;
	for (i = 0; i < width; i++) {
		drow[i] = (float3){(ta[i].x + tb[i].x) * 0.5f,
						   (ta[i].y + tb[i].y) * 0.5f,
						   (ta[i].z + tb[i].z) * 0.5f};
	}
}

