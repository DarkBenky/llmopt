void VisualizeBuffer(const Camera *camera, int mode)
{
	if (mode == 0) return; 
	const int n = camera->screenWidth * camera->screenHeight;

	if (mode == 1) { 
		const float3 *normals = camera->normalBuffer;
		Color *framebuffer = camera->framebuffer;
		for (int i = 0; i < n; i++) {
			float3 nm = normals[i];
			framebuffer[i] = PackColorSafe(
				nm.x * 0.5f + 0.5f,
				nm.y * 0.5f + 0.5f,
				nm.z * 0.5f + 0.5f);
		}
		return;
	}

	if (mode == 3) { 
		const float3 *reflects = camera->reflectBuffer;
		Color *framebuffer = camera->framebuffer;
		for (int i = 0; i < n; i++) {
			float3 r = reflects[i];
			framebuffer[i] = PackColorSafe(
				r.x * 0.5f + 0.5f,
				r.y * 0.5f + 0.5f,
				r.z * 0.5f + 0.5f);
		}
		return;
	}

	if (mode == 2) { 
		float dMin = 1e38f, dMax = 0.0f;
		const float *depths = camera->depthBuffer;
		for (int i = 0; i < n; i++) {
			float d = depths[i];
			if (d > 0.0f && d < 1e38f) {
				if (d < dMin) dMin = d;
				if (d > dMax) dMax = d;
			}
		}
		float range = dMax - dMin;
		if (range < 1e-6f) range = 1.0f;
		for (int i = 0; i < n; i++) {
			float d = depths[i];
			float t = (d <= 0.0f || d >= 1e38f) ? 0.0f : 1.0f - (d - dMin) / range;
			camera->framebuffer[i] = PackColorSafe(t, t, t);
		}
	}
}

