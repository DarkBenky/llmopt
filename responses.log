	if (!src) {
		printf("[CL] failed to load kernel file: %s\n", path);
		return (CL_Pipeline){0};
	}
	CL_Pipeline pip = CL_Pipeline_FromSource(ctx, src, kernel_name, options);
	free(src);
	return pip;
}

