------------------------------------------------------------
static inline float3 RotateXYZ(float3 v, float3 rotation)
{
	float c0 = cosf(rotation.x);
	float s0 = sinf(rotation.x);
	float c1 = cosf(rotation.y);
	float s1 = sinf(rotation.y);
	float c2 = cosf(rotation.z);
	float s2 = sinf(rotation.z);

	float x = v.x;
	float y = v.y;
	float z = v.z;

	// Apply RotateX
	x = x;
	float temp1 = y * c0 - z * s0;
	float temp2 = y * s0 + z * c0;

	// Apply RotateY
	float temp3 = x * c1 + z * s1;
	float temp4 = y;
	float temp5 = -x * s1 + z * c1;

	// Apply RotateZ
	float temp6 = temp3 * c2 - temp4 * s2;
	float temp7 = temp3 * s2 + temp4 * c2;
	float temp8 = temp5;

	return (float3){
		temp6,
		temp7,
		temp8
	};
}

