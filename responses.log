static inline float3 Float3_Lerp(float3 a, float3 b, float t)
{
	float3 result;
	result.x = a.x + t * (b.x - a.x);
	result.y = a.y + t * (b.y - a.y);
	result.z = a.z + t * (b.z - a.z);
	return result;
}

