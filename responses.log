void drawTileColorScaled(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y, float scaleX, float scaleY, uint32 color)
{
	int scaledW = (int)(tile.width * scaleX);
	int scaledH = (int)(tile.height * scaleY);

	int dstX = x, dstY = y;
	int srcX = 0, srcY = 0;
	if (dstX < 0) {
		srcX -= (int)(dstX / scaleX);
		dstX = 0;
	}
	if (dstY < 0) {
		srcY -= (int)(dstY / scaleY);
		dstY = 0;
	}
	if (dstX + scaledW > dstWidth) scaledW = dstWidth - dstX;
	if (dstY + scaledH > dstHeight) scaledH = dstHeight - dstY;

	if (scaledW <= 0 || scaledH <= 0) return;

	int srcStride = tile.width;
	int dstStride = dstWidth;

	// Vectorize inner loop with 4x4 tile
	for (int row = 0; row < scaledH; row += 4) {
		for (int col = 0; col < scaledW; col += 4) {
			int srcRow = srcY + (int)(row / scaleY);
			int srcCol = srcX + (int)(col / scaleX);
			int srcOffset = srcRow * srcStride + srcCol;

			// Load 4 pixels from tile
			uint32 src0 = tile.pixels[srcOffset];
			uint32 src1 = tile.pixels[srcOffset + 1];
			uint32 src2 = tile.pixels[srcOffset + 2];
			uint32 src3 = tile.pixels[srcOffset + 3];

			int dstOff0 = (dstY + row) * dstStride + (dstX + col);
			int dstOff1 = (dstY + row + 1) * dstStride + (dstX + col);
			int dstOff2 = (dstY + row + 2) * dstStride + (dstX + col);
			int dstOff3 = (dstY + row + 3) * dstStride + (dstX + col);

			// Check if non-zero and write
			if (src0 != 0x00000000) dst[dstOff0] = color;
			if (src1 != 0x00000000) dst[dstOff1] = color;
			if (src2 != 0x00000000) dst[dstOff2] = color;
			if (src3 != 0x00000000) dst[dstOff3] = color;
		}
