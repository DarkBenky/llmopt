step=860  func=ApplyExposure  reward=-0.0128
------------------------------------------------------------
Color ApplyExposure(Color c, float exposure)
{
	float3 col = UnpackColor(c);
	float expFactor = powf(2.0f, exposure);
	col.x *= expFactor;
	col.y *= expFactor;
	col.z *= expFactor;
	return PackColorF(col);
}

