void RenderText(uint32 *dst, int dstWidth, int dstHeight, struct Alphabet *alphabet, const char *text, int x, int y, float scale, uint32 color)
{
	if (!dst || !alphabet || !text) return;

	if (scale <= 0.0f) scale = 1.0f;

	int cursorX = x;
	for (size_t i = 0; text[i] != '\0'; i++) {
		unsigned char code = (unsigned char)text[i];
		Tile tile = alphabet->letters[code].tile;

		if (tile.pixels && tile.width > 0 && tile.height > 0) {
			int scaledW = (int)(tile.width * scale);
			int scaledH = (int)(tile.height * scale);
			int dstX = x, dstY = y;
			int srcX = 0, srcY = 0;
			if (dstX < 0) {
				srcX -= (int)(dstX / scale);
				dstX = 0;
			}
			if (dstY < 0) {
				srcY -= (int)(dstY / scale);
				dstY = 0;
			}
			if (dstX + scaledW > dstWidth) scaledW = dstWidth - dstX;
			if (dstY + scaledH > dstHeight) scaledH = dstHeight - dstY;

			if (scaledW <= 0 || scaledH <= 0) return;

			int srcStride = tile.width;
			int dstStride = dstWidth;

			for (int row = 0; row < scaledH; row++) {
				int srcRow = srcY + (int)(row / scale);
				int dstRow = dstY + row;
				for (int col = 0; col < scaledW; col++) {
					int srcCol = srcX + (int)(col / scale);
					uint32 src = tile.pixels[srcRow * srcStride + srcCol];
					if (src != 0x00000000)
						dst[dstRow * dstStride + (dstX + col)] = color;
				}
			}
		} else {
			cursorX += (int)(8.0f * scale);
		}
	}
