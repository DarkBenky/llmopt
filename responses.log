static float rayAABB(float3 ro, float3 rd, float3 mn, float3 mx)
{
	float tmin = 0.0f, tmax = FLT_MAX;
	const float *o = &ro.x, *d = &rd.x, *bmin = &mn.x, *bmax = &mx.x;
	__m128 t0, t1, tmin_vec, tmax_vec;
	__m128 invD, t0_vec, t1_vec;
	__m128 zero = _mm_setzero_ps();
	__m128 one = _mm_set1_ps(1.0f);
	__m128 invD_vec[3];
	float invD_f[3];
	for (int i = 0; i < 3; i++) {
		if (fabsf(d[i]) < 1e-8f) {
			if (o[i] < bmin[i] || o[i] > bmax[i]) return FLT_MAX;
			continue;
		}
		invD_f[i] = 1.0f / d[i];
		invD_vec[i] = _mm_set1_ps(invD_f[i]);
		float t0_f = (bmin[i] - o[i]) * invD_f[i];
		float t1_f = (bmax[i] - o[i]) * invD_f[i];
		t0_vec = _mm_set_ps(t0_f, 0.0f, 0.0f, 0.0f);
		t1_vec = _mm_set_ps(t1_f, 0.0f, 0.0f, 0.0f);
		if (t0_f > t1_f) {
			__m128 tmp = t0_vec;
			t0_vec = t1_vec;
			t1_vec = tmp;
		}
		tmin_vec = _mm_max_ps(tmin_vec, t0_vec);
		tmax_vec = _mm_min_ps(tmax_vec, t1_vec);
		if (_mm_cvtss_f32(_mm_max_ps(tmin_vec, tmax_vec)) > tmax) return FLT_MAX;
	}
	return _mm_cvtss_f32(tmin_vec);
}

