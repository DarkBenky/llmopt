static inline float3 RotateXYZ(float3 v, float3 rotation)
{
	float c0 = cosf(rotation.x);
	float s0 = sinf(rotation.x);
	float c1 = cosf(rotation.y);
	float s1 = sinf(rotation.y);
	float c2 = cosf(rotation.z);
	float s2 = sinf(rotation.z);

	float x = v.x;
	float y = v.y;
	float z = v.z;

	// Apply X rotation first
	x = x;
	float temp_y = y * c0 - z * s0;
	float temp_z = y * s0 + z * c0;

	// Apply Y rotation
	float temp_x = x * c1 + temp_z * s1;
	float temp_y2 = temp_y;
	float temp_z2 = -x * s1 + temp_z * c1;

	// Apply Z rotation
	float final_x = temp_x * c2 - temp_y2 * s2;
	float final_y = temp_x * s2 + temp_y2 * c2;
	float final_z = temp_z2;

	return (float3){
		final_x,
		final_y,
		final_z};
}

