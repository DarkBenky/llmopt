------------------------------------------------------------
void clearBuffers(Camera *camera)
{
	if (!camera) return;
	int size = camera->screenWidth * camera->screenHeight;
	
	uint32 *fb = camera->framebuffer;
	int4 *acc = camera->accumulationBuffer;
	float3 *norm = camera->normalBuffer;
	float3 *pos = camera->positionBuffer;
	float3 *refl = camera->reflectBuffer;
	float3 *bloom = camera->bloomBuffer;
	float3 *bloomTemp = camera->bloomTemp;
	float3 *bloomDst = camera->bloomDst;
	float *depth = camera->depthBuffer;
	int *obj = camera->objectIdBuffer;
	int *frame = &camera->frameCounter;
	
	// Hoist invariants and use vectorized clear patterns
	// Clear all buffers with SIMD-friendly, cache-friendly patterns
	// Use aligned memset for contiguous arrays
	if (fb) memset(fb, 0, size * sizeof(uint32));
	if (acc) memset(acc, 0, size * sizeof(int4));
	if (norm) memset(norm, 0, size * sizeof(float3));
	if (pos) memset(pos, 0, size * sizeof(float3));
	if (refl) memset(refl, 0, size * sizeof(float3));
	if (bloom) memset(bloom, 0, size * sizeof(float3));
	if (bloomTemp) memset(bloomTemp, 0, size * sizeof(float3));
	if (bloomDst) memset(bloomDst, 0, size * sizeof(float3));
	if (depth) memset(depth, 0, size * sizeof(float));
	if (obj) memset(obj, 0, size * sizeof(int));
	if (frame) *frame = 0;
}

