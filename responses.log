			srcCol = srcX + (int)(col / scaleX);
			srcRow = srcY + (int)(row / scaleY);
			uint32 src = tile.pixels[srcRow * tile.width + srcCol];
			if (src != 0x00000000)
				dst[(dstY + row) * dstWidth + (dstX + col)] = color;
		}
	}
}

