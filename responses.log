	float gray = 0.299f * col.x + 0.587f * col.y + 0.114f * col.z;
	float scale = saturation;
	float inv_scale = 1.0f - saturation;
	col.x = col.x * scale + gray * inv_scale;
	col.y = col.y * scale + gray * inv_scale;
	col.z = col.z * scale + gray * inv_scale;
	return PackColorF(col);
}

