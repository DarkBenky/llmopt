bool ObjectBehindCamera(const Object *obj, float3 camPos, float3 camForward)
{
    float3 mn = obj->worldBBmin;
    float3 mx = obj->worldBBmax;
    float3 corners[8] = {
        {mn.x, mn.y, mn.z},
        {mx.x, mn.y, mn.z},
        {mn.x, mx.y, mn.z},
        {mx.x, mx.y, mn.z},
        {mn.x, mn.y, mx.z},
        {mx.x, mn.y, mx.z},
        {mn.x, mx.y, mx.z},
        {mx.x, mx.y, mx.z},
    };
    float3 toCorner[8];
    for (int i = 0; i < 8; i++) {
        toCorner[i] = (float3){
            corners[i].x - camPos.x,
            corners[i].y - camPos.y,
            corners[i].z - camPos.z,
        };
        if (toCorner[i].x * camForward.x + toCorner[i].y * camForward.y + toCorner[i].z * camForward.z >= 0.0f)
            return false;
    }
    return true;
}

