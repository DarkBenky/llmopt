------------------------------------------------------------
static inline void DecimateBuffer(float3 *src, float3 *dst, int width, int height, int factor)
{
	int dstWidth = width / factor;
	int dstHeight = height / factor;
	float invSamples = 1.0f / (float)(factor * factor);
	__m128 accum_x = _mm_setzero_ps();
	__m128 accum_y = _mm_setzero_ps();
	__m128 accum_z = _mm_setzero_ps();
	__m128 invSamples_vec = _mm_set1_ps(invSamples);
	for (int y = 0; y < dstHeight; y++) {
		for (int x = 0; x < dstWidth; x++) {
			accum_x = _mm_setzero_ps();
			accum_y = _mm_setzero_ps();
			accum_z = _mm_setzero_ps();
			for (int ky = 0; ky < factor; ky++) {
				const float3 *row = src + (y * factor + ky) * width + x * factor;
				for (int kx = 0; kx < factor; kx++) {
					__m128 x_val = _mm_load_ps(&row[kx].x);
					__m128 y_val = _mm_load_ps(&row[kx].y);
					__m128 z_val = _mm_load_ps(&row[kx].z);
					accum_x = _mm_add_ps(accum_x, x_val);
					accum_y = _mm_add_ps(accum_y, y_val);
					accum_z = _mm_add_ps(accum_z, z_val);
				}
			}
			__m128 accum_x_final = _mm_mul_ps(accum_x, invSamples_vec);
			__m128 accum_y_final = _mm_mul_ps(accum_y, invSamples_vec);
			__m128 accum_z_final = _mm_mul_ps(accum_z, invSamples_vec);
			_mm_store_ps(&dst[y * dstWidth + x].x, accum_x_final);
			_mm_store_ps(&dst[y * dstWidth + x].y, accum_y_final);
			_mm_store_ps(&dst[y * dstWidth + x].z, accum_z_final);
		}
	}
}

