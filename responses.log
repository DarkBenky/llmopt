------------------------------------------------------------
void drawTile(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}

	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	const size_t rowBytes = (size_t)copyW * sizeof(uint32);
	int rows = copyH;
	int srcOffset = srcY * tile.width + srcX;
	int dstOffset = y * dstWidth + x;

	// Vectorize memcpy for 4x4 blocks
	int block = 16;
	for (int row = 0; row < rows; row += block) {
		int thisBlock = (row + block < rows) ? block : rows - row;
		if (thisBlock == 0) break;

		// Hoist constants, unroll loop
		const uint32 *src = tile.pixels + srcOffset;
		uint32 *dstPtr = dst + dstOffset;
		const uint32 *srcEnd = src + thisBlock;
		const uint32 *srcEnd2 = src + thisBlock + 1;
		const uint32 *srcEnd3 = src + thisBlock + 2;
		const uint32 *srcEnd4 = src + thisBlock + 3;

		// SIMD unroll for 4x4 blocks
		if (thisBlock >= 4) {
			// Unroll 4 iterations
			const uint32 *src0 = src;
			const uint32 *src1 = src + 1;
			const uint32 *src2 = src + 2;
			const uint32 *src3 = src + 3;

			uint32 *dst0 = dstPtr;
			uint32 *dst1 = dst0 + 4;
			uint32 *dst2 = dst1 + 4;
			uint32 *dst3 = dst2 + 4;

			// Vectorize 4x4 block with 4 SIMD lanes
			__m128i v0 = _mm_loadu_si128((const __m128i*)src0);
			__m128i v1 = _mm_loadu_si128((const __m128i*)src1);
			__m128i v2 = _mm_loadu_si128((const __m128i*)src2);
			__m128i v3 = _mm_loadu_si128((const __m128i*)src3);

			_mm_storeu_si128((__m128i*)dst0, v0);
			_mm_storeu_si128((__m128i*)dst1, v1);
			_mm_storeu_si128((__m128i*)dst2, v2);
			_mm_storeu_si128((__m128i*)dst3, v3);

			// Handle remaining elements if any
			if (thisBlock > 4) {
				int rem = thisBlock - 4;
				for (int i = 0; i < rem; i++) {
					dstPtr[i] = src[i];
				}
			}
		} else {
			// Fallback for small blocks
			for (int i = 0; i < thisBlock; i++) {
				dstPtr[i] = src[i];
			}
		}

		dstOffset += 4;
		srcOffset += 4;
	}

	// Handle remaining rows
	for (int row = 0; row < rows; row++) {
		if (row >= rows) break;
		int idx = row * tile.width + srcX;
		dst[row * dstWidth + x] = tile.pixels[idx];
	}
}

