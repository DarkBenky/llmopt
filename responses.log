void Object_SetMaterial(Object *obj, MaterialLib *lib, Material mat)
{
    int triangleCount = obj->triangleCount;
    Material *entries = lib->entries;
    int *materialIds = obj->materialIds;

    // Vectorize inner loop using SSE2 for 4 updates at a time
    #pragma omp simd
    for (int i = 0; i < triangleCount; i += 4) {
        int idx0 = i;
        int idx1 = i + 1;
        int idx2 = i + 2;
        int idx3 = i + 3;

        if (idx0 < triangleCount) entries[materialIds[idx0]] = mat;
        if (idx1 < triangleCount) entries[materialIds[idx1]] = mat;
        if (idx2 < triangleCount) entries[materialIds[idx2]] = mat;
        if (idx3 < triangleCount) entries[materialIds[idx3]] = mat;
    }
}

