static inline float FastSeed(float cameraSeed)
{
	uint32 h = (uint32)(cameraSeed * 1013904223.0f);
	h ^= h >> 16;
	h *= 0x45d9f3bu;
	h ^= h >> 16;
	return (float)h * 2.3283064365e-10f;
}

