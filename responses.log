step=861  func=ApplyToneMapping  reward=0.0025
------------------------------------------------------------
Color ApplyToneMapping(Color c)
{
	float3 col = UnpackColor(c);
	col.x = col.x / (col.x + 1.0f);
	col.y = col.y / (col.y + 1.0f);
	col.z = col.z / (col.z + 1.0f);
	return PackColorF(col);
}

