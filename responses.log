step=73  func=DecimateBuffer  reward=0.0236
------------------------------------------------------------
static inline void DecimateBuffer(float3 *src, float3 *dst, int width, int height, int factor)
{
	int dstWidth = width / factor;
	int dstHeight = height / factor;
	float invSamples = 1.0f / (float)(factor * factor);
	__m128i zero = _mm_setzero_si128();
	__m128i zero_f = _mm_setzero_ps();
	for (int y = 0; y < dstHeight; y++) {
		for (int x = 0; x < dstWidth; x++) {
			__m128i accum_x = zero, accum_y = zero, accum_z = zero;
			for (int ky = 0; ky < factor; ky++) {
				const float3 *row = src + (y * factor + ky) * width + x * factor;
				__m128i kx = zero;
				for (int kx = 0; kx < factor; kx++) {
					__m128i px = _mm_load_ps((float*)(&row[kx].x));
					__m128i py = _mm_load_ps((float*)(&row[kx].y));
					__m128i pz = _mm_load_ps((float*)(&row[kx].z));
					accum_x = _mm_add_ps(accum_x, px);
					accum_y = _mm_add_ps(accum_y, py);
					accum_z = _mm_add_ps(accum_z, pz);
				}
			}
			__m128i res_x = _mm_mul_ps(accum_x, _mm_set_ps1(invSamples));
			__m128i res_y = _mm_mul_ps(accum_y, _mm_set_ps1(invSamples));
			__m128i res_z = _mm_mul_ps(accum_z, _mm_set_ps1(invSamples));
			_mm_store_ps((float*)(&dst[y * dstWidth + x].x), res_x);
			_mm_store_ps((float*)(&dst[y * dstWidth + x].y), res_y);
			_mm_store_ps((float*)(&dst[y * dstWidth + x].z), res_z);
		}
	}
}

