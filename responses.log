step=85  func=RenderSetup  reward=0.0636
------------------------------------------------------------
void RenderSetup(const Object *objects, int objectCount, Camera *camera)
{
	if (!objects || !camera || objectCount <= 0) return;
	camera->seed += FastSeed(camera->seed) + 0.01f;
	float3 forward = camera->forward;
	float3 right = Float3_Cross((float3){0, 1, 0}, forward);
	right = Float3_Normalize(right);
	float3 up = Float3_Cross(forward, right);
	camera->right = right;
	camera->up = up;
	camera->aspect = (float)camera->screenWidth / (float)camera->screenHeight;
	float fovRad = camera->fov * 0.5f * 3.14159265f / 180.0f;
	camera->fovScale = tanf(fovRad);
	camera->viewDir = Float3_Scale(forward, -1.0f);
	float3 renderLightDir = (float3){0.5f, 0.7f, -0.5f};
	camera->renderLightDir = Float3_Normalize(renderLightDir);
	float3 viewDir = camera->viewDir;
	float3 halfVec = Float3_Add(renderLightDir, viewDir);
	halfVec = Float3_Normalize(halfVec);
	camera->halfVec = halfVec;
}

