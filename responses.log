step=542  func=RandomHemisphereDirection  reward=-0.0057
------------------------------------------------------------
static inline float3 RandomHemisphereDirection(float3 normal, float seed)
{
	float r1 = RandomFloat(seed);
	float r2 = RandomFloat(seed + 1.0f);

	float a = 2.0f * r1 - 1.0f;
	float b = 2.0f * r2 - 1.0f;
	float phi, rad;
	if (a * a > b * b) {
		rad = a;
		phi = (M_PI / 4.0f) * (b / a);
	} else if (b != 0.0f) {
		rad = b;
		phi = (M_PI / 2.0f) - (M_PI / 4.0f) * (a / b);
	} else {
		return normal;
	}
	float sx = rad * cosf(phi);
	float sy = rad * sinf(phi);
	float cosTheta = sqrtf(fmaxf(0.0f, 1.0f - sx * sx - sy * sy));

	float sign = (normal.z >= 0.0f) ? 1.0f : -1.0f;
	float aa = -1.0f / (sign + normal.z);
	float bb = normal.x * normal.y * aa;
	float t_x = 1.0f + sign * normal.x * normal.x * aa;
	float t_y = sign * bb;
	float t_z = -sign * normal.x;
	float b3_x = bb;
	float b3_y = sign + normal.y * normal.y * aa;
	float b3_z = -normal.y;

	return (float3){
		sx * t_x + sy * b3_x + cosTheta * normal.x,
		sx * t_y + sy * b3_y + cosTheta * normal.y,
		sx * t_z + sy * b3_z + cosTheta * normal.z,
	};
}

