static inline float3 Float3_Min(float3 a, float3 b)
{
	__m128 m1 = _mm_load_ps(&a.x);
	__m128 m2 = _mm_load_ps(&b.x);
	__m128 m3 = _mm_min_ss(m1, m2);
	__m128 m4 = _mm_load_ps(&a.y);
	__m128 m5 = _mm_load_ps(&b.y);
	__m128 m6 = _mm_min_ss(m4, m5);
	__m128 m7 = _mm_load_ps(&a.z);
	__m128 m8 = _mm_load_ps(&b.z);
	__m128 m9 = _mm_min_ss(m7, m8);
	__m128i result = _mm_castps_si128(_mm_shuffle_ps(m3, m6, _MM_SHUFFLE(0,0,0,0)));
	result = _mm_or_si128(result, _mm_castps_si128(_mm_shuffle_ps(m6, m9, _MM_SHUFFLE(0,0,0,0))));
	result = _mm_or_si128(result, _mm_castps_si128(_mm_shuffle_ps(m9, m3, _MM_SHUFFLE(0,0,0,0))));
	return (float3){_mm_extract_ps(_mm_castsi128_ps(result), 0), _mm_extract_ps(_mm_castsi128_ps(result), 1), _mm_extract_ps(_mm_castsi128_ps(result), 2)};
}

