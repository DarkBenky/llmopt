void DestroySkybox(Skybox *skybox)
{
	if (!skybox) return;
	// Hoist free calls to reduce branch misprediction
	// Use vectorized memory operations for array of pointers
	// Since all pointers are uint32*, we can vectorize if aligned
	// However, no SIMD needed here due to small, fixed number of pointers
	// Just sequential freeing with nulling pointers

	// Vectorize by using a mask of 6 pointers, but since no SIMD intrinsic
	// available for free() and pointer nulling, we do sequential
	// But we can hoist the nulling to avoid redundant writes

	uint32 **ptrs[6] = { &skybox->front, &skybox->back, &skybox->left, &skybox->right, &skybox->top, &skybox->bottom };
	for (int i = 0; i < 6; i++) {
		if (*ptrs[i]) {
			free(*ptrs[i]);
			*ptrs[i] = NULL;
		}
	}
}

