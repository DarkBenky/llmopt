static inline float3 TransformPointTRS(float3 local, float3 position, float3 rotation, float3 scale)
{
	float3 scaled = {
		local.x * scale.x,
		local.y * scale.y,
		local.z * scale.z};
	float3 rotated = RotateXYZ(scaled, rotation);
	return (float3){
		rotated.x + position.x,
		rotated.y + position.y,
		rotated.z + position.z};
}

