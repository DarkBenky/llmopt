step=710  func=PackColorSafe  reward=-0.0066
------------------------------------------------------------
Color PackColorSafe(float r, float g, float b)
{
	uint8 R = (uint8)(r > 1.0f ? 255 : r < 0.0f ? 0 : (int)(r * 255.0f));
	uint8 G = (uint8)(g > 1.0f ? 255 : g < 0.0f ? 0 : (int)(g * 255.0f));
	uint8 B = (uint8)(b > 1.0f ? 255 : b < 0.0f ? 0 : (int)(b * 255.0f));
	return 0xFF000000 | (Color)(R << 16) | (Color)(G << 8) | B;
}

