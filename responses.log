step=15  func=ComputeCentroid  reward=-0.0247
------------------------------------------------------------
float3 ComputeCentroid(const Object *obj, const int *ObjectIdx, int ObjectsCount)
{
	float3 centroid = {0, 0, 0};
	float3 *v1, *v2, *v3;
	int i, j;

	for (i = 0; i < ObjectsCount; i++) {
		int idx = ObjectIdx[i];
		v1 = obj[idx].v1;
		v2 = obj[idx].v2;
		v3 = obj[idx].v3;
		for (j = 0; j < obj[idx].triangleCount; j++) {
			centroid.x += (v1[j].x + v2[j].x + v3[j].x) / 3.0f;
			centroid.y += (v1[j].y + v2[j].y + v3[j].y) / 3.0f;
			centroid.z += (v1[j].z + v2[j].z + v3[j].z) / 3.0f;
		}
	}
	if (ObjectsCount > 0) {
		float invCount = 1.0f / ObjectsCount;
		centroid.x *= invCount;
		centroid.y *= invCount;
		centroid.z *= invCount;
	}
	return centroid;
}

