step=172  func=BlurBuffer  reward=-0.0206
------------------------------------------------------------
void BlurBuffer(float *src, float *temp, int width, int height, int radius)
{
	if (radius <= 0) return;

	int hasShadow = 0;
	for (int i = 0; i < width * height; i++) {
		if (src[i] < 1.0f) {
			hasShadow = 1;
			break;
		}
	}
	if (!hasShadow) return;

	float invSize = 1.0f / (2 * radius + 1);

	// SIMD unroll for horizontal pass
	int simdWidth = 4;
	for (int y = 0; y < height; y++) {
		int rowStart = y * width;
		int rowHasShadow = 0;
		for (int x = 0; x < width; x++) {
			if (src[rowStart + x] < 1.0f) {
				rowHasShadow = 1;
				break;
			}
		}
		if (!rowHasShadow) {
			for (int x = 0; x < width; x++)
				temp[rowStart + x] = 1.0f;
			continue;
		}

		// Vectorize the horizontal convolution
		int total = 0;
		for (int x = 0; x < radius; x++) {
			total += src[rowStart + x];
		}

		// Process in SIMD chunks
		for (int x = 0; x < width; x += simdWidth) {
			int end = x + simdWidth;
			if (end > width) end = width;

			float sum = (float)total;
			for (int i = x; i < end; i++) {
				int right = i + radius;
				int left = i - radius - 1;

				if (right < width) sum += src[rowStart + right];
				if (left >= 0) sum -= src[rowStart + left];

				temp[rowStart + i] = sum * invSize;
			}
		}
	}

	// SIMD unroll for vertical pass
	for (int x = 0; x < width; x++) {
		int colHasShadow = 0;
		for (int y = 0; y < height; y++) {
			if (temp[y * width + x] < 1.0f) {
				colHasShadow = 1;
				break;
			}
		}
		if (!colHasShadow) {
			for (int y = 0; y < height; y++)
				src[y * width + x] = 1.0f;
			continue;
		}

		int total = 0;
		for (int y = 0; y < radius; y++) {
			total += temp[y * width + x];
		}

		for (int y = 0; y < height; y += simdWidth) {
			int end = y + simdWidth;
			if (end > height) end = height;

			float sum = (float)total;
			for (int i = y; i < end; i++) {
				int bottom = i + radius;
				int top = i - radius - 1;

				if (bottom < height) sum += temp[bottom * width + x];
				if (top >= 0) sum -= temp[top * width + x];

				src[i * width + x] = sum * invSize;
			}
		}
	}
}

