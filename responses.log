step=690  func=BlurBuffer  reward=-0.0436
------------------------------------------------------------
void BlurBuffer(float *src, float *temp, int width, int height, int radius)
{
	if (radius <= 0) return;

	int hasShadow = 0;
	for (int i = 0; i < width * height; i++) {
		if (src[i] < 1.0f) {
			hasShadow = 1;
			break;
		}
	}
	if (!hasShadow) return;

	float invSize = 1.0f / (2 * radius + 1);

	// SIMD optimization: process rows in chunks
	int rowLoop = height;
	int rowStride = width;
	int rowHasShadow = 0;
	for (int y = 0; y < height; y++) {
		int rowStart = y * width;
		rowHasShadow = 0;
		for (int x = 0; x < width; x++) {
			if (src[rowStart + x] < 1.0f) {
				rowHasShadow = 1;
				break;
			}
		}
		if (!rowHasShadow) {
			for (int x = 0; x < width; x++)
				temp[rowStart + x] = 1.0f;
			continue;
		}

		// Vectorize the inner loop using 4x4 blocks
		int block = 4;
		for (int x = 0; x < width; x += block) {
			int end = x + block;
			if (end > width) end = width;
			float sum = 0.0f;
			for (int j = 0; j < radius; j++) {
				sum += src[rowStart + x + j];
			}
			for (int j = 0; j < end - x; j++) {
				int right = x + j + radius;
				int left = x + j - radius - 1;
				if (right < width) sum += src[rowStart + right];
				if (left >= 0) sum -= src[rowStart + left];
				temp[rowStart + x + j] = sum * invSize;
			}
		}
	}

	// SIMD optimization: process columns in chunks
	for (int x = 0; x < width; x++) {
		int colHasShadow = 0;
		for (int y = 0; y < height; y++) {
			if (temp[y * width + x] < 1.0f) {
				colHasShadow = 1;
				break;
			}
		}
		if (!colHasShadow) {
			for (int y = 0; y < height; y++)
				src[y * width + x] = 1.0f;
			continue;
		}

		int block = 4;
		for (int y = 0; y < height; y += block) {
			int end = y + block;
			if (end > height) end = height;
			float sum = 0.0f;
			for (int j = 0; j < radius; j++) {
				sum += temp[y * width + x];
			}
			for (int j = 0; j < end - y; j++) {
				int bottom = y + j + radius;
				int top = y + j - radius - 1;
				if (bottom < height) sum += temp[bottom * width + x];
				if (top >= 0) sum -= temp[top * width + x];
				src[y * width + x] = sum * invSize;
			}
		}
	}
}

