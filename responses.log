void drawTileScaled(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y, float scaleX, float scaleY)
{
	int scaledW = (int)(tile.width * scaleX);
	int scaledH = (int)(tile.height * scaleY);

	int dstX = x;
	int dstY = y;
	int srcX = 0;
	int srcY = 0;
	if (dstX < 0) {
		srcX -= (int)(dstX / scaleX);
		dstX = 0;
	}
	if (dstY < 0) {
		srcY -= (int)(dstY / scaleY);
		dstY = 0;
	}

	if (dstX + scaledW > dstWidth) scaledW = dstWidth - dstX;
	if (dstY + scaledH > dstHeight) scaledH = dstHeight - dstY;

	if (scaledW <= 0 || scaledH <= 0) return;

	int srcRow, srcCol;
	int dstIdx;
	int row, col;

	// Vectorize inner loop with 4x4 tile
	for (row = 0; row < scaledH; row += 4) {
		for (col = 0; col < scaledW; col += 4) {
			srcRow = srcY + (int)(row / scaleY);
			srcCol = srcX + (int)(col / scaleX);

			// Compute 4x4 tile of source pixels
			int srcRow0 = srcRow;
			int srcRow1 = srcRow + 1;
			int srcRow2 = srcRow + 2;
			int srcRow3 = srcRow + 3;

			int srcCol0 = srcCol;
			int srcCol1 = srcCol + 1;
			int srcCol2 = srcCol + 2;
			int srcCol3 = srcCol + 3;

			// Compute 4x4 tile of destination pixels
			dstIdx = (dstY + row) * dstWidth + (dstX + col);
			int dstIdx0 = dstIdx;
			int dstIdx1 = dstIdx + 1;
			int dstIdx2 = dstIdx + 2;
			int dstIdx3 = dstIdx + 3;

			// Vectorize 4x4 tile
			uint32 src0 = tile.pixels[srcRow0 * tile.width + srcCol0];
			uint32 src1 = tile.pixels[srcRow1 * tile.width + srcCol1];
			uint32 src2 = tile.pixels[srcRow2 * tile.width + srcCol2];
			uint32 src3 = tile.pixels[srcRow3 * tile.width + srcCol3];

			dst[dstIdx0] = src0;
			dst[dstIdx1] = src1;
			dst[dstIdx2] = src2;
			dst[dstIdx3] = src3;

			// Process next 4x4 tile
			if (row + 4 < scaledH && col + 4 < scaledW) {
				srcRow = srcY + (int)((row + 4) / scaleY);
				srcCol = srcX + (int)((col + 4) / scaleX);

				srcRow0 = srcRow;
				srcRow1 = srcRow + 1;
				srcRow2 = srcRow + 2;
				srcRow3 = srcRow + 3;

				srcCol0 = srcCol;
				srcCol1 = srcCol + 1;
				srcCol2 = srcCol + 2;
				srcCol3 = srcCol + 3;

				dstIdx = (dstY + row + 4) * dstWidth + (dstX + col + 4);
				dstIdx0 = dstIdx;
				dstIdx1 = dstIdx + 1;
				dstIdx2 = dstIdx + 2;
				dstIdx3 = dstIdx + 3;

				src0 = tile.pixels[srcRow0 * tile.width + srcCol0];
				src1 = tile.pixels[srcRow1 * tile.width + srcCol1];
				src2 = tile.pixels[srcRow2 * tile.width + srcCol2];
				src3 = tile.pixels[srcRow3 * tile.width + srcCol3];

				dst[dstIdx0] = src0;
				dst[dstIdx1] = src1;
				dst[dstIdx2] = src2;
				dst[dstIdx3] = src3;
			}
		}
	}
}

