    if (count == 0) return;
    int *materialIds = obj->materialIds;
    Material *entries = lib->entries;
    int capacity = lib->capacity;

    // Use SIMD to process 4 materials at a time
    #pragma omp simd
    for (int i = 0; i < count; i += 4) {
        entries[materialIds[i]].metallic = metallic;
        if (i + 1 < count) entries[materialIds[i + 1]].metallic = metallic;
        if (i + 2 < count) entries[materialIds[i + 2]].metallic = metallic;
        if (i + 3 < count) entries[materialIds[i + 3]].metallic = metallic;
    }
}

