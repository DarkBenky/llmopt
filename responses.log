static float rayAABB(float3 ro, float3 rd, float3 mn, float3 mx)
{
	float tmin = 0.0f, tmax = FLT_MAX;
	const float *o = &ro.x, *d = &rd.x, *bmin = &mn.x, *bmax = &mx.x;
	float invD[3];
	for (int i = 0; i < 3; i++) {
		if (fabsf(d[i]) < 1e-8f) {
			if (o[i] < bmin[i] || o[i] > bmax[i]) return FLT_MAX;
			continue;
		}
		invD[i] = 1.0f / d[i];
		float t0 = (bmin[i] - o[i]) * invD[i];
		float t1 = (bmax[i] - o[i]) * invD[i];
		if (t0 > t1) {
			float tmp = t0;
			t0 = t1;
			t1 = tmp;
		}
		tmin = MaxF32(tmin, t0);
		tmax = MinF32(tmax, t1);
		if (tmin > tmax) return FLT_MAX;
	}
	return tmin;
}

