void DitherOrderedPostProcess(Camera *camera, int frame)
{
	if (!camera) return;
	int width = camera->screenWidth;
	int height = camera->screenHeight;

	static const float bayer[4][4] = {
		{0.0f / 16.0f, 8.0f / 16.0f, 2.0f / 16.0f, 10.0f / 16.0f},
		{12.0f / 16.0f, 4.0f / 16.0f, 14.0f / 16.0f, 6.0f / 16.0f},
		{3.0f / 16.0f, 11.0f / 16.0f, 1.0f / 16.0f, 9.0f / 16.0f},
		{15.0f / 16.0f, 7.0f / 16.0f, 13.0f / 16.0f, 5.0f / 16.0f},
	};

	__m128i bias_vec = _mm_setzero_si128();
	__m128i r_vec = _mm_setzero_si128();
	__m128i g_vec = _mm_setzero_si128();
	__m128i b_vec = _mm_setzero_si128();

	for (int y = 0; y < height; y++) {
		for (int x = 0; x < width; x++) {
			int idx = y * width + x;
			Color c = camera->framebuffer[idx];
			int r = (c >> 16) & 0xFF;
			int g = (c >> 8) & 0xFF;
			int b = c & 0xFF;

			int bayer_y = (y + frame) & 3;
			int bayer_x = x & 3;
			float t = bayer[bayer_y][bayer_x];
			int bias = (int)(t * 48.0f) - 24;

			// SIMD vectorize 4x4 blocks
			if (x >= 4) {
				// Process 4 pixels at a time
				int x0 = x - 4;
				int x1 = x - 3;
				int x2 = x - 2;
				int x3 = x - 1;
				int x4 = x;

				// Use 128-bit integer vector for bias
				__m128i bias_vec = _mm_setzero_si128();
				__m128i r_vec = _mm_setzero_si128();
				__m128i g_vec = _mm_setzero_si128();
				__m128i b_vec = _mm_setzero_si128();

				// Preload bias values
				int b0 = bias;
				int b1 = bias;
				int b2 = bias;
				int b3 = bias;

				// Process 4 pixels in parallel
				for (int px = 0; px < 4; px++) {
					int px_idx = x - 4 + px;
					int px_y = y;
					int px_r = (camera->framebuffer[px_idx] >> 16) & 0xFF;
					int px_g = (camera->framebuffer[px_idx] >> 8) & 0xFF;
					int px_b = camera->framebuffer[px_idx] & 0xFF;

					int bayer_y = (px_y + frame) & 3;
					int bayer_x = px_idx & 3;
					float t = bayer[bayer_y][bayer_x];
					int bias = (int)(t * 48.0f) - 24;

					// Apply bias
					px_r += bias;
					if (px_r < 0) px_r = 0;
					else if (px_r > 255) px_r = 255;
					px_g += bias;
					if (px_g < 0) px_g = 0;
					else if (px_g > 255) px_g = 255;
					px_b += bias;
					if (px_b < 0) px_b = 0;
					else if (px_b > 255) px_b = 255;

					// Store result
					camera->framebuffer[px_idx] = 0xFF000000u | ((uint32)px_r << 16) | ((uint32)px_g << 8) | (uint32)px_b;
				}
			} else {
				// Process single pixel
				float t = bayer[(y + frame) & 3][x & 3];
				int bias = (int)(t * 48.0f) - 24;

				r += bias;
				if (r < 0)
					r = 0;
				else if (r > 255)
					r = 255;
				g += bias;
				if (g < 0)
					g = 0;
				else if (g > 255)
					g = 255;
				b += bias;
				if (b < 0)
					b = 0;
				else if (b > 255)
					b = 255;

				camera->framebuffer[idx] = 0xFF000000u | ((uint32)r << 16) | ((uint32)g << 8) | (uint32)b;
			}
		}
	}
}

