------------------------------------------------------------
static inline void DecimateBuffer(float3 *src, float3 *dst, int width, int height, int factor)
{
	int dstWidth = width / factor;
	int dstHeight = height / factor;
	float invSamples = 1.0f / (float)(factor * factor);
	__m128i zero = _mm_setzero_si128();
	__m128i mask = _mm_set1_epi32(0x00000001);
	__m128i one = _mm_set1_epi32(1);
	__m128i factor_i = _mm_set1_epi32(factor);
	__m128i invSamples_i = _mm_set1_ps(invSamples);
	__m128 zero_ps = _mm_setzero_ps();
	__m128 accum_x = zero_ps, accum_y = zero_ps, accum_z = zero_ps;
	__m128 accum_x_vec = zero_ps, accum_y_vec = zero_ps, accum_z_vec = zero_ps;
	__m128i accum_x_i = zero, accum_y_i = zero, accum_z_i = zero;
	int x, y, ky, kx;
	for (y = 0; y < dstHeight; y++) {
		for (x = 0; x < dstWidth; x++) {
			accum_x = zero_ps;
			accum_y = zero_ps;
			accum_z = zero_ps;
			accum_x_vec = zero_ps;
			accum_y_vec = zero_ps;
			accum_z_vec = zero_ps;
			accum_x_i = zero;
			accum_y_i = zero;
			accum_z_i = zero;
			for (ky = 0; ky < factor; ky++) {
				const float3 *row = src + (y * factor + ky) * width + x * factor;
				for (kx = 0; kx < factor; kx++) {
					accum_x = _mm_add_ps(accum_x, _mm_set_ps(0.0f, row[kx].x, 0.0f, 0.0f));
					accum_y = _mm_add_ps(accum_y, _mm_set_ps(0.0f, row[kx].y, 0.0f, 0.0f));
					accum_z = _mm_add_ps(accum_z, _mm_set_ps(0.0f, row[kx].z, 0.0f, 0.0f));
				}
			}
			dst[y * dstWidth + x] = (float3){
				_mm_cvtss_f32(_mm_add_ps(accum_x, _mm_setzero_ps())),
				_mm_cvtss_f32(_mm_add_ps(accum_y, _mm_setzero_ps())),
				_mm_cvtss_f32(_mm_add_ps(accum_z, _mm_setzero_ps()))
			};
		}
	}
}

