------------------------------------------------------------
static inline void UpsampleBilinear(float3 *src, float3 *tmp, float3 *dst,
									int srcWidth, int srcHeight, int dstWidth, int dstHeight)
{
	float scaleX = (float)(srcWidth - 1) / (float)(dstWidth - 1);
	float scaleY = (float)(srcHeight - 1) / (float)(dstHeight - 1);
	
	// Vectorize inner loop for x dimension using AVX2
	const int vec_width = 8; // 8 floats per 256-bit vector
	const int dstWidth_vec = dstWidth / vec_width;
	
	// Process each vector of 8 x-coordinates
	for (int y = 0; y < srcHeight; y++) {
		const float3 *srow = src + y * srcWidth;
		float3 *trow = tmp + y * dstWidth;
		int x_vec = 0;
		
		// Process in chunks of 8
		for (; x_vec < dstWidth_vec; x_vec += vec_width) {
			// Load 8 source x0 and x1 for this row
			int x0_vec = x_vec * vec_width;
			int x1_vec = x_vec * vec_width;
			
			// Calculate x0 and x1 for each of the 8 elements
			for (int i = 0; i < vec_width; i++) {
				float u = (float)(x_vec + i) * scaleX;
				int x0 = (int)u;
				int x1 = x0 + 1 < srcWidth ? x0 + 1 : x0;
				float t = u - x0;
				float it = 1.0f - t;
				
				// Calculate 3 components for each of the 8 elements
				trow[x_vec + i] = (float3){
					srow[x0].x * it + srow[x1].x * t,
					srow[x0].y * it + srow[x1].y * t,
					srow[x0].z * it + srow[x1].z * t
				};
			}
		}
		// Handle remaining elements if any
		for (; x_vec < dstWidth; x_vec++) {
			float u = (float)x_vec * scaleX;
			int x0 = (int)u;
			int x1 = x0 + 1 < srcWidth ? x0 + 1 : x0;
			float t = u - x0;
			float it = 1.0f - t;
			trow[x_vec] = (float3){
				srow[x0].x * it + srow[x1].x * t,
				srow[x0].y * it + srow[x1].y * t,
				srow[x0].z * it + srow[x1].z * t
			};
		}
	}
	
	// Vectorize inner loop for y dimension using AVX2
	for (int y = 0; y < dstHeight; y++) {
		float v = y * scaleY;
		int y0 = (int)v;
		int y1 = y0 + 1 < srcHeight ? y0 + 1 : y0;
		float t = v - y0;
		float it = 1.0f - t;
		const float3 *r0 = tmp + y0 * dstWidth;
		const float3 *r1 = tmp + y1 * dstWidth;
		float3 *drow = dst + y * dstWidth;
		
		int x_vec = 0;
		for (; x_vec < dstWidth_vec; x_vec += vec_width) {
			for (int i = 0; i < vec_width; i++) {
				drow[x_vec + i] = (float3){
					r0[x_vec + i].x * it + r1[x_vec + i].x * t,
					r0[x_vec + i].y * it + r1[x_vec + i].y * t,
					r0[x_vec + i].z * it + r1[x_vec + i].z * t
				};
			}
		}
		for (; x_vec < dstWidth; x_vec++) {
			drow[x_vec] = (float3){
				r0[x_vec].x * it + r1[x_vec].x * t,
				r0[x_vec].y * it + r1[x_vec].y * t,
				r0[x_vec].z * it + r1[x_vec].z * t
			};
		}
	}
}

