void CameraMoveRight(Camera *camera, float amount)
{
	if (!camera) return;
	float3 right = Float3_Cross(camera->forward, (float3){0.0f, 1.0f, 0.0f});
	float x = right.x * amount;
	float y = right.y * amount;
	float z = right.z * amount;
	camera->position.x += x;
	camera->position.y += y;
	camera->position.z += z;
}

