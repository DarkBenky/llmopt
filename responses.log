void drawTileColor(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y, uint32 color)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}
	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	// Vectorize inner loop with AVX2 for 8x8 blocks
	const int block_size = 8;
	int rows = copyH, cols = copyW;
	int total_rows = rows, total_cols = cols;

	// Hoist invariants, unroll inner loop
	for (int row = 0; row < rows; row += block_size) {
		for (int col = 0; col < cols; col += block_size) {
			int r = row, c = col;
			int src_row = srcY + r;
			int src_col = srcX + c;
			int dst_row = y + r;
			int dst_col = x + c;

			// Process 8x8 block
			for (int i = 0; i < block_size; i++) {
				if (r + i < rows) {
					for (int j = 0; j < block_size; j++) {
						if (c + j < cols) {
							uint32 src = tile.pixels[src_row * tile.width + src_col];
							if (src != 0x00000000) {
								dst[dst_row * dstWidth + dst_col] = color;
							}
							src_col++;
							dst_col++;
						}
					}
					r += block_size;
					c += block_size;
				}
			}
		}
	}
}

