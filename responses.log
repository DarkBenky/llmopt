Color ApplyGamma(Color c, float gamma)
{
	float3 col = UnpackColor(c);
	__m128 vgamma = _mm_set_ss(gamma);
	__m128 inv_gamma = _mm_div_ss(_mm_set_ss(1.0f), vgamma);
	__m128 v1 = _mm_set_ss(1.0f / gamma);
	__m128 v2 = _mm_set_ss(1.0f / gamma);
	__m128 v3 = _mm_set_ss(1.0f / gamma);
	float3 result = {0.0f, 0.0f, 0.0f};
	result.x = _mm_cvtss_f32(_mm_div_ss(_mm_set_ss(1.0f), _mm_set_ss(gamma)));
	result.y = _mm_cvtss_f32(_mm_div_ss(_mm_set_ss(1.0f), _mm_set_ss(gamma)));
	result.z = _mm_cvtss_f32(_mm_div_ss(_mm_set_ss(1.0f), _mm_set_ss(gamma)));
