static inline float Q_rsqrt(float number)
{
	union {
		float f;
		uint32_t i;
	} conv = {.f = number};
	conv.i = 0x5F375A86 - (conv.i >> 1);
	conv.f *= 1.5f - (number * 0.5f * conv.f * conv.f);
	return conv.f;
}

