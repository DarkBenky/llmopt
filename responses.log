step=609  func=ApplyRotMat3  reward=0.0374
------------------------------------------------------------
static inline float3 ApplyRotMat3(float3 v, RotMat3 m)
{
	__m128 v0 = _mm_set_ps(0.0f, v.z, v.y, v.x);
	__m128 m00 = _mm_set_ps(0.0f, m.m[0][2], m.m[0][1], m.m[0][0]);
	__m128 m10 = _mm_set_ps(0.0f, m.m[1][2], m.m[1][1], m.m[1][0]);
	__m128 m20 = _mm_set_ps(0.0f, m.m[2][2], m.m[2][1], m.m[2][0]);
	__m128 v1 = _mm_set_ps(0.0f, v.z, v.y, v.x);
	__m128 v2 = _mm_set_ps(0.0f, v.z, v.y, v.x);
	__m128 res0 = _mm_mul_ps(v0, m00);
	__m128 res1 = _mm_mul_ps(v1, m10);
	__m128 res2 = _mm_mul_ps(v2, m20);
	__m128 res = _mm_add_ps(res0, res1);
	res = _mm_add_ps(res, res2);
	return (float3){res0[0], res1[0], res2[0]};
}

