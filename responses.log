bool ObjectBehindCamera(const Object *obj, float3 camPos, float3 camForward)
{
	float3 mn = obj->worldBBmin;
	float3 mx = obj->worldBBmax;

	float3 corners[8] = {
		{mn.x, mn.y, mn.z},
		{mx.x, mn.y, mn.z},
		{mn.x, mx.y, mn.z},
		{mx.x, mx.y, mn.z},
		{mn.x, mn.y, mx.z},
		{mx.x, mn.y, mx.z},
		{mn.x, mx.y, mx.z},
		{mx.x, mx.y, mx.z},
	};

	float3 toCorner;
	float3 camForwardScaled = camForward;

	for (int i = 0; i < 8; i++) {
		toCorner.x = corners[i].x - camPos.x;
		toCorner.y = corners[i].y - camPos.y;
		toCorner.z = corners[i].z - camPos.z;

		if (toCorner.x * camForwardScaled.x + toCorner.y * camForwardScaled.y + toCorner.z * camForwardScaled.z >= 0.0f)
			return false;
	}

	return true;
}

