Color ScaleColor(Color c, float s)
{
	float3 col = UnpackColor(c);
	__m128 s_vec = _mm_set_ps1(s);
	__m128 r_vec = _mm_set_ss(col.x);
	__m128 g_vec = _mm_set_ss(col.y);
	__m128 b_vec = _mm_set_ss(col.z);
	__m128i r_vec_i = _mm_castps_si128(_mm_set_ps1(col.x));
	__m128i g_vec_i = _mm_castps_si128(_mm_set_ps1(col.y));
	__m128i b_vec_i = _mm_castps_si128(_mm_set_ps1(col.z));
	r_vec = _mm_mul_ps(r_vec, s_vec);
	g_vec = _mm_mul_ps(g_vec, s_vec);
	b_vec = _mm_mul_ps(b_vec, s_vec);
	r_vec_i = _mm_mul_ps(_mm_castsi128_ps(r_vec_i), s_vec);
	g_vec_i = _mm_mul_ps(_mm_castsi128_ps(g_vec_i), s_vec);
	b_vec_i = _mm_mul_ps(_mm_castsi128_ps(b_vec_i), s_vec);
	col.x = _mm_cvtss_f32(_mm_shuffle_ps(r_vec, r_vec, 0));
	col.y = _mm_cvtss_f32(_mm_shuffle_ps(g_vec, g_vec, 0));
	col.z = _mm_cvtss_f32(_mm_shuffle_ps(b_vec, b_vec, 0));
	return PackColorF(col);
}

