step=827  func=RotateXYZ  reward=0.0010
------------------------------------------------------------
static inline float3 RotateXYZ(float3 v, float3 rotation)
{
	float c0 = cosf(rotation.x);
	float s0 = sinf(rotation.x);
	float c1 = cosf(rotation.y);
	float s1 = sinf(rotation.y);
	float c2 = cosf(rotation.z);
	float s2 = sinf(rotation.z);

	float x = v.x;
	float y = v.y;
	float z = v.z;

	// Apply RotateX
	float y1 = y * c0 - z * s0;
	float z1 = y * s0 + z * c0;

	// Apply RotateY
	float x1 = x * c1 + z1 * s1;
	float z2 = -x * s1 + z1 * c1;

	// Apply RotateZ
	float x2 = x1 * c2 - y1 * s2;
	float y2 = x1 * s2 + y1 * c2;

	return (float3){x2, y2, z2};
}

