	__m128 m4 = _mm_set_ps(0.0f, 0.5f, 0.5f, 0.5f);
	__m128 m5 = _mm_mul_ps(_mm_sub_ps(m1, m2), m3);
	__m128 m6 = _mm_add_ps(m5, m4);
	float3 out = (float3){_mm_cvtss_f32(m6), _mm_cvtss_f32(m6), _mm_cvtss_f32(m6)};
	return PackColorF(out);
}

