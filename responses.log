static inline float3 hdrToLDR(float fr, float fg, float fb)
{
	float e = fmaxf(fmaxf(fr, fg), fb) - 1.0f;
	if (e > 0.0f) {
		fr += e;
		fg += e;
		fb += e;
		fr = fminf(fr, 1.0f);
		fg = fminf(fg, 1.0f);
		fb = fminf(fb, 1.0f);
	}
	return (float3){fr, fg, fb};
}

