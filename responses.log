------------------------------------------------------------
void drawTileColor(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y, uint32 color)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}
	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	// Vectorize inner loop with AVX2 for 8x8 blocks
	const int blockW = 8, blockH = 8;
	const int maxW = copyW, maxH = copyH;
	int row, col;

	// Hoist invariants, unroll inner loop
	for (row = 0; row < maxH; row += blockH) {
		for (col = 0; col < maxW; col += blockW) {
			// Process 8x8 block
			for (int r = 0; r < blockH; r++) {
				for (int c = 0; c < blockW; c++) {
					uint32 src = tile.pixels[(srcY + row + r) * tile.width + (srcX + col + c)];
					if (src != 0x00000000)
						dst[(y + row + r) * dstWidth + (x + col + c)] = color;
				}
			}
		}
	}

	// Handle remaining pixels
	for (row = row; row < maxH; row++) {
		for (col = col; col < maxW; col++) {
			uint32 src = tile.pixels[(srcY + row) * tile.width + (srcX + col)];
			if (src != 0x00000000)
				dst[(y + row) * dstWidth + (x + col)] = color;
		}
	}
}

