void DitherPostProcess(Camera *camera, int frame)
{
	if (!camera) return;
	int width = camera->screenWidth;
	int height = camera->screenHeight;

	if (width == 0 || height == 0) return;

	uint32 *fb = camera->framebuffer;
	int *w = &width, *h = &height;

	for (int y = 0; y < height; y++) {
		for (int x = 0; x < width; x++) {
			int idx = y * width + x;
			Color c = fb[idx];
			int r = (c >> 16) & 0xFF;
			int g = (c >> 8) & 0xFF;
			int b = c & 0xFF;

			uint32 h = (uint32)(x * 1619 + y * 31337 + frame * 6791);
			h ^= h >> 16;
			h *= 0x45d9f3bu;
			h ^= h >> 16;
			int bias = (int)(h & 0xFF) - 128;
			bias = bias * 24 / 128;

			r += bias;
			if (r < 0) r = 0;
			else if (r > 255) r = 255;

			g += bias;
			if (g < 0) g = 0;
			else if (g > 255) g = 255;

			b += bias;
			if (b < 0) b = 0;
			else if (b > 255) b = 255;

			fb[idx] = 0xFF000000u | ((uint32)r << 16) | ((uint32)g << 8) | (uint32)b;
		}
	}
}

