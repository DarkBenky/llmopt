void drawTile(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}

	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	const size_t rowBytes = (size_t)copyW * sizeof(uint32);
	int copyW4 = copyW >> 2;
	int copyH4 = copyH >> 2;
	int copyW2 = copyW & 3;
	int copyH2 = copyH & 3;

	for (int row = 0; row < copyH; row++) {
		uint32 *dstRow = dst + (y + row) * dstWidth + x;
		const uint32 *srcRow = tile.pixels + (srcY + row) * tile.width + srcX;
		int srcRowBytes = copyW;
		int dstRowBytes = copyW;

		if (copyW4 > 0) {
			__m128i *dstVec = (void *)dstRow;
			__m128i *srcVec = (void *)srcRow;
			for (int i = 0; i < copyW4; i++) {
				*dstVec = *srcVec;
				dstVec++;
				srcVec++;
			}
		}
		if (copyW2 > 0) {
			for (int i = 0; i < copyW2; i++) {
				dstRow[i] = srcRow[i];
			}
		}
	}
}

