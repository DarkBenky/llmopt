------------------------------------------------------------
static void BlurColorBuffer(Color *src, Color *temp, int width, int height, int radius)
{
	if (radius <= 0) return;

	// Precompute radius bounds for cache efficiency
	int x0, x1, y0, y1;
	x0 = radius;
	x1 = width - 1 - radius;
	y0 = radius;
	y1 = height - 1 - radius;

	// First pass: horizontal blur
	for (int y = 0; y < height; y++) {
		const Color *row = src + y * width;
		Color *out = temp + y * width;
		for (int x = 0; x < width; x++) {
			uint32 r = 0, g = 0, b = 0, n = 0;
			int k = x - radius;
			if (k < 0) k = 0;
			int end = x + radius;
			if (end >= width) end = width - 1;
			for (int i = k; i <= end; i++) {
				Color c = row[i];
				if (!c) continue;
				r += (c >> 16) & 0xFF;
				g += (c >> 8) & 0xFF;
				b += c & 0xFF;
				n++;
			}
			out[x] = n ? (0xFF000000u | ((r / n) << 16) | ((g / n) << 8) | (b / n)) : 0;
		}
	}

	// Second pass: vertical blur
	for (int y = 0; y < height; y++) {
		for (int x = 0; x < width; x++) {
			uint32 r = 0, g = 0, b = 0, n = 0;
			int k = y - radius;
			if (k < 0) k = 0;
			int end = y + radius;
			if (end >= height) end = height - 1;
			for (int i = k; i <= end; i++) {
				Color c = temp[i * width + x];
				if (!c) continue;
				r += (c >> 16) & 0xFF;
				g += (c >> 8) & 0xFF;
				b += c & 0xFF;
				n++;
			}
			src[y * width + x] = n ? (0xFF000000u | ((r / n) << 16) | ((g / n) << 8) | (b / n)) : 0;
		}
	}
}

