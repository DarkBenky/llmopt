void drawTile(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}

	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	const size_t rowBytes = (size_t)copyW * sizeof(uint32);
	const int simdWidth = 4;
	const int simdCount = copyW / simdWidth;
	const int simdRemain = copyW % simdWidth;

	if (simdRemain == 0) {
		for (int row = 0; row < copyH; row++) {
			__m128i *dstVec = (__m128i *)(dst + (y + row) * dstWidth + x);
			__m128i *srcVec = (__m128i *)(tile.pixels + (srcY + row) * tile.width + srcX);
			for (int i = 0; i < simdCount; i++) {
				*dstVec = *srcVec;
				dstVec++;
				srcVec++;
			}
		}
	} else {
		for (int row = 0; row < copyH; row++) {
			__m128i *dstVec = (__m128i *)(dst + (y + row) * dstWidth + x);
			__m128i *srcVec = (__m128i *)(tile.pixels + (srcY + row) * tile.width + srcX);
			for (int i = 0; i < simdCount; i++) {
				*dstVec = *srcVec;
				dstVec++;
				srcVec++;
			}
			for (int i = 0; i < simdRemain; i++) {
				*dstVec = *srcVec;
				dstVec++;
				srcVec++;
			}
		}
	}
}

