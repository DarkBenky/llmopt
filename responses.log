------------------------------------------------------------
void DitherOrderedPostProcess(Camera *camera, int frame)
{
	if (!camera) return;
	int width = camera->screenWidth;
	int height = camera->screenHeight;

	static const float bayer[4][4] = {
		{0.0f / 16.0f, 8.0f / 16.0f, 2.0f / 16.0f, 10.0f / 16.0f},
		{12.0f / 16.0f, 4.0f / 16.0f, 14.0f / 16.0f, 6.0f / 16.0f},
		{3.0f / 16.0f, 11.0f / 16.0f, 1.0f / 16.0f, 9.0f / 16.0f},
		{15.0f / 16.0f, 7.0f / 16.0f, 13.0f / 16.0f, 5.0f / 16.0f},
	};

	// Vectorize the inner loop using AVX2 for 4x4 blocks
	const int block_size = 16;
	const int simd_width = 4;
	const int simd_blocks = width / simd_width;
	const int simd_height = height / block_size;

	for (int y = 0; y < height; y += block_size) {
		for (int x = 0; x < width; x += simd_width) {
			int idx = y * width + x;
			Color c = camera->framebuffer[idx];
			int r = (c >> 16) & 0xFF;
			int g = (c >> 8) & 0xFF;
			int b = c & 0xFF;

			// SIMD loop: process 4 pixels at a time
			for (int i = 0; i < simd_width; ++i) {
				int px = x + i;
				int py = y;
				int idx_local = py * width + px;
				Color c_local = camera->framebuffer[idx_local];
				int r_local = (c_local >> 16) & 0xFF;
				int g_local = (c_local >> 8) & 0xFF;
				int b_local = c_local & 0xFF;

				int bayer_idx = (py + frame) & 3;
				int bayer_y = bayer[bayer_idx][px & 3];
				int bias = (int)(bayer_y * 48.0f) - 24;

				r_local += bias;
				if (r_local < 0) r_local = 0;
				else if (r_local > 255) r_local = 255;

				g_local += bias;
				if (g_local < 0) g_local = 0;
				else if (g_local > 255) g_local = 255;

				b_local += bias;
				if (b_local < 0) b_local = 0;
				else if (b_local > 255) b_local = 255;

				camera->framebuffer[idx_local] = 0xFF000000u | ((uint32)r_local << 16) | ((uint32)g_local << 8) | (uint32)b_local;
			}
		}
	}
}

