step=808  func=UpsampleBilinear  reward=-0.1084
------------------------------------------------------------
static inline void UpsampleBilinear(float3 *src, float3 *tmp, float3 *dst,
									int srcWidth, int srcHeight, int dstWidth, int dstHeight)
{
	float scaleX = (float)(srcWidth - 1) / (float)(dstWidth - 1);
	float scaleY = (float)(srcHeight - 1) / (float)(dstHeight - 1);
	
	// Vectorize inner loop with AVX2 for 4x4 blocks
	for (int y = 0; y < srcHeight; y++) {
		const float3 *srow = src + y * srcWidth;
		float3 *trow = tmp + y * dstWidth;
		int block = dstWidth / 4;
		for (int x = 0; x < block; x++) {
			float u = x * scaleX;
			int x0 = (int)u;
			int x1 = x0 + 1 < srcWidth ? x0 + 1 : x0;
			float t = u - x0;
			float it = 1.0f - t;
			__m256i x0i = _mm256_set1_epi32(x0);
			__m256i x1i = _mm256_set1_epi32(x1);
			__m256i tvec = _mm256_set1_ps(t);
			__m256i itvec = _mm256_set1_ps(it);
			
			// Load 4x3 floats from src[x0] and src[x1]
			__m256 s0 = _mm256_load_ps(&srow[x0].x);
			__m256 s1 = _mm256_load_ps(&srow[x1].x);
			__m256 s2 = _mm256_load_ps(&srow[x0].y);
			__m256 s3 = _mm256_load_ps(&srow[x1].y);
			__m256 s4 = _mm256_load_ps(&srow[x0].z);
			__m256 s5 = _mm256_load_ps(&srow[x1].z);
			
			// Interpolate x0 and x1 for each channel
			__m256 interp0 = _mm256_mul_ps(s0, itvec);
			__m256 interp1 = _mm256_mul_ps(s1, tvec);
			__m256 out0 = _mm256_add_ps(interp0, interp1);
			
			__m256 interp0y = _mm256_mul_ps(s2, itvec);
			__m256 interp1y = _mm256_mul_ps(s3, tvec);
			__m256 out1 = _mm256_add_ps(interp0y, interp1y);
			
			__m256 interp0z = _mm256_mul_ps(s4, itvec);
			__m256 interp1z = _mm256_mul_ps(s5, tvec);
			__m256 out2 = _mm256_add_ps(interp0z, interp1z);
			
			// Store result
			_mm256_store_ps(&trow[x].x, out0);
			_mm256_store_ps(&trow[x].y, out1);
			_mm256_store_ps(&trow[x].z, out2);
		}
	}
	
	// Vectorize second pass
	for (int y = 0; y < dstHeight; y++) {
		float v = y * scaleY;
		int y0 = (int)v;
		int y1 = y0 + 1 < srcHeight ? y0 + 1 : y0;
		float t = v - y0;
		float it = 1.0f - t;
		
		const float3 *r0 = tmp + y0 * dstWidth;
		const float3 *r1 = tmp + y1 * dstWidth;
		float3 *drow = dst + y * dstWidth;
		int block = dstWidth / 4;
		for (int x = 0; x < block; x++) {
			__m256i y0i = _mm256_set1_epi32(y0);
			__m256i y1i = _mm256_set1_epi32(y1);
			__m256i tvec = _mm256_set1_ps(t);
			__m256i itvec = _mm256_set1_ps(it);
			
			// Load 4x3 floats from tmp
			__m256 s0 = _mm256_load_ps(&r0[x].x);
			__m256 s1 = _mm256_load_ps(&r1[x].x);
			__m256 s2 = _mm256_load_ps(&r0[x].y);
			__m256 s3 = _mm256_load_ps(&r1[x].y);
			__m256 s4 = _mm256_load_ps(&r0[x].z);
			__m256 s5 = _mm256_load_ps(&r1[x].z);
			
			// Interpolate
			__m256 interp0 = _mm256_mul_ps(s0, itvec);
			__m256 interp1 = _mm256_mul_ps(s1, tvec);
			__m256 out0 = _mm256_add_ps(interp0, interp1);
			
			__m256 interp0y = _mm256_mul_ps(s2, itvec);
			__m256 interp1y = _mm256_mul_ps(s3, tvec);
			__m256 out1 = _mm256_add_ps(interp0y, interp1y);
			
			__m256 interp0z = _mm256_mul_ps(s4, itvec);
			__m256 interp1z = _mm256_mul_ps(s5, tvec);
			__m256 out2 = _mm256_add_ps(interp0z, interp1z);
			
			// Store result
			_mm256_store_ps(&drow[x].x, out0);
			_mm256_store_ps(&drow[x].y, out1);
			_mm256_store_ps(&drow[x].z, out2);
		}
	}
}

