void DitherOrderedPostProcess(Camera *camera, int frame)
{
	if (!camera) return;
	int width = camera->screenWidth;
	int height = camera->screenHeight;

	static const float bayer[4][4] = {
		{0.0f / 16.0f, 8.0f / 16.0f, 2.0f / 16.0f, 10.0f / 16.0f},
		{12.0f / 16.0f, 4.0f / 16.0f, 14.0f / 16.0f, 6.0f / 16.0f},
		{3.0f / 16.0f, 11.0f / 16.0f, 1.0f / 16.0f, 9.0f / 16.0f},
		{15.0f / 16.0f, 7.0f / 16.0f, 13.0f / 16.0f, 5.0f / 16.0f},
	};

	const int simd_width = 4;
	const int simd_height = 4;
	const int simd_iter = (height + simd_height - 1) / simd_height;
	const int simd_iter_width = (width + simd_width - 1) / simd_width;

	for (int y = 0; y < height; y += simd_height) {
		for (int x = 0; x < width; x += simd_width) {
			int y0 = y;
			int x0 = x;
			int idx0 = y0 * width + x0;
			int idx1 = (y0 + 1) * width + x0;
			int idx2 = (y0 + 2) * width + x0;
			int idx3 = (y0 + 3) * width + x0;

			Color c0 = camera->framebuffer[idx0];
			Color c1 = camera->framebuffer[idx1];
			Color c2 = camera->framebuffer[idx2];
			Color c3 = camera->framebuffer[idx3];

			int r0 = (c0 >> 16) & 0xFF;
			int g0 = (c0 >> 8) & 0xFF;
			int b0 = c0 & 0xFF;

			int r1 = (c1 >> 16) & 0xFF;
			int g1 = (c1 >> 8) & 0xFF;
			int b1 = c1 & 0xFF;

			int r2 = (c2 >> 16) & 0xFF;
			int g2 = (c2 >> 8) & 0xFF;
			int b2 = c2 & 0xFF;

			int r3 = (c3 >> 16) & 0xFF;
			int g3 = (c3 >> 8) & 0xFF;
			int b3 = c3 & 0xFF;

			float t0 = bayer[(y0 + frame) & 3][x0 & 3];
			float t1 = bayer[(y0 + 1 + frame) & 3][x0 & 3];
			float t2 = bayer[(y0 + 2 + frame) & 3][x0 & 3];
			float t3 = bayer[(y0 + 3 + frame) & 3][x0 & 3];

			int bias0 = (int)(t0 * 48.0f) - 24;
			int bias1 = (int)(t1 * 48.0f) - 24;
			int bias2 = (int)(t2 * 48.0f) - 24;
			int bias3 = (int)(t3 * 48.0f) - 24;

			r0 += bias0;
			if (r0 < 0) r0 = 0;
			else if (r0 > 255) r0 = 255;

			r1 += bias1;
			if (r1 < 0) r1 = 0;
			else if (r1 > 255) r1 = 255;

			r2 += bias2;
			if (r2 < 0) r2 = 0;
			else if (r2 > 255) r2 = 255;

			r3 += bias3;
			if (r3 < 0) r3 = 0;
			else if (r3 > 255) r3 = 255;

			g0 += bias0;
			if (g0 < 0) g0 = 0;
			else if (g0 > 255) g0 = 255;

			g1 += bias1;
			if (g1 < 0) g1 = 0;
			else if (g1 > 255) g1 = 255;

			g2 += bias2;
			if (g2 < 0) g2 = 0;
			else if (g2 > 255) g2 = 255;

			g3 += bias3;
			if (g3 < 0) g3 = 0;
			else if (g3 > 255) g3 = 255;

			b0 += bias0;
			if (b0 < 0) b0 = 0;
			else if (b0 > 255) b0 = 255;

			b1 += bias1;
			if (b1 < 0) b1 = 0;
			else if (b1 > 255) b1 = 255;

			b2 += bias2;
			if (b2 < 0) b2 = 0;
			else if (b2 > 255) b2 = 255;

			b3 += bias3;
			if (b3 < 0) b3 = 0;
			else if (b3 > 255) b3 = 255;

			camera->framebuffer[idx0] = 0xFF000000u | ((uint32)r0 << 16) | ((uint32)g0 << 8) | (uint32)b0;
			camera->framebuffer[idx1] = 0xFF000000u | ((uint32)r1 << 16) | ((uint32)g1 << 8) | (uint32)b1;
			camera->framebuffer[idx2] = 0xFF000000u | ((uint32)r2 << 16) | ((uint32)g2 << 8) | (uint32)b2;
			camera->framebuffer[idx3] = 0xFF000000u | ((uint32)r3 << 16) | ((uint32)g3 << 8) | (uint32)b3;
		}
	}
}

