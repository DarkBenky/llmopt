static inline float3 TransformPoint(const Object *obj, float3 local)
{
	float3 scaled = {
		local.x * obj->scale.x,
		local.y * obj->scale.y,
		local.z * obj->scale.z};
	float3 rotated = RotateXYZ(scaled, obj->rotation);
	return (float3){
		rotated.x + obj->position.x,
		rotated.y + obj->position.y,
		rotated.z + obj->position.z};
}

