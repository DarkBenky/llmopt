void BlurRowUoutput(Camera *camera, int row, uint32 *output)
{
	if (!camera || row < 0 || row >= camera->screenHeight) return;
	int width = camera->screenWidth;
	int stride = camera->screenWidth;
	uint32 *fb = camera->framebuffer;
	uint32 *out = output;
	int4 accum = {0, 0, 0, 0};
	for (int col = 0; col < width; col++) {
		int red = 0, green = 0, blue = 0;
		int count = 0;
		for (int dy = -1; dy <= 1; dy++) {
			for (int dx = -1; dx <= 1; dx++) {
				int x = col + dx;
				int y = row + dy;
				if (x >= 0 && x < width && y >= 0 && y < camera->screenHeight) {
					Color c = fb[y * stride + x];
					int4 rgb = UnpackColorInt(c);
					red += rgb.x;
					green += rgb.y;
					blue += rgb.z;
					count++;
				}
			}
		}
		out[col] = PackColorSafe((float)red / count / 255.0f, (float)green / count / 255.0f, (float)blue / count / 255.0f);
	}
}

