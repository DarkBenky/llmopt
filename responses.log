static void SSRRowTask(void *arg)
{
	SSRTask *task = arg;
	int rowStart = task->row;
	int rowCount = task->rowCount;
	Camera *camera = task->camera;
	int screenHeight = camera->screenHeight;

	for (int r = rowStart; r < rowStart + rowCount && r < screenHeight; r++) {
		SSRProcessRow(camera, r);
	}
}

