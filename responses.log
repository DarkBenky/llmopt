static inline float3 PositionToRayDir(float3 from, float3 to)
{
	float3 v = Float3_Sub(to, from);
	float len = Float3_Length(v);
	if (len > 0.0f) {
		float invLen = 1.0f / len;
		return (float3){v.x * invLen, v.y * invLen, v.z * invLen};
	}
	return v;
}
