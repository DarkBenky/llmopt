void drawTileColor(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y, uint32 color)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}
	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	int srcStride = tile.width;
	int dstStride = dstWidth;

	// Hoist invariants, unroll inner loop for better SIMD potential
	for (int row = 0; row < copyH; row++) {
		uint32 *dstRow = dst + (y + row) * dstStride;
		const uint32 *srcRow = tile.pixels + (srcY + row) * srcStride;

		for (int col = 0; col < copyW; col += 4) {
			uint32 src0 = srcRow[col];
			uint32 src1 = srcRow[col + 1];
			uint32 src2 = srcRow[col + 2];
			uint32 src3 = srcRow[col + 3];

			if (src0 != 0x00000000) dstRow[col] = color;
			if (src1 != 0x00000000) dstRow[col + 1] = color;
			if (src2 != 0x00000000) dstRow[col + 2] = color;
			if (src3 != 0x00000000) dstRow[col + 3] = color;
		}
	}
}

