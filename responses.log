------------------------------------------------------------
void VisualizeBuffer(const Camera *camera, int mode)
{
	if (mode == 0) return; 
	const int n = camera->screenWidth * camera->screenHeight;

	if (mode == 1) { 
		float3* nm = camera->normalBuffer;
		uint8* fb = camera->framebuffer;
		for (int i = 0; i < n; i++) {
			float3 nmv = nm[i];
			uint8 R = (uint8)(nmv.x * 0.5f + 0.5f > 1.0f ? 255 : nmv.x * 0.5f + 0.5f < 0.0f ? 0 : (int)(nmv.x * 0.5f + 0.5f * 255.0f));
			uint8 G = (uint8)(nmv.y * 0.5f + 0.5f > 1.0f ? 255 : nmv.y * 0.5f + 0.5f < 0.0f ? 0 : (int)(nmv.y * 0.5f + 0.5f * 255.0f));
			uint8 B = (uint8)(nmv.z * 0.5f + 0.5f > 1.0f ? 255 : nmv.z * 0.5f + 0.5f < 0.0f ? 0 : (int)(nmv.z * 0.5f + 0.5f * 255.0f));
			fb[i] = 0xFF000000 | (Color)(R << 16) | (Color)(G << 8) | B;
		}
		return;
	}

	if (mode == 3) { 
		float3* r = camera->reflectBuffer;
		uint8* fb = camera->framebuffer;
		for (int i = 0; i < n; i++) {
			float3 rvec = r[i];
			uint8 R = (uint8)(rvec.x * 0.5f + 0.5f > 1.0f ? 255 : rvec.x * 0.5f + 0.5f < 0.0f ? 0 : (int)(rvec.x * 0.5f + 0.5f * 255.0f));
			uint8 G = (uint8)(rvec.y * 0.5f + 0.5f > 1.0f ? 255 : rvec.y * 0.5f + 0.5f < 0.0f ? 0 : (int)(rvec.y * 0.5f + 0.5f * 255.0f));
			uint8 B = (uint8)(rvec.z * 0.5f + 0.5f > 1.0f ? 255 : rvec.z * 0.5f + 0.5f < 0.0f ? 0 : (int)(rvec.z * 0.5f + 0.5f * 255.0f));
			fb[i] = 0xFF000000 | (Color)(R << 16) | (Color)(G << 8) | B;
		}
		return;
	}

	if (mode == 2) { 
		float* d = camera->depthBuffer;
		uint8* fb = camera->framebuffer;
		float dMin = 1e38f, dMax = 0.0f;
		for (int i = 0; i < n; i++) {
			float dval = d[i];
			if (dval > 0.0f && dval < 1e38f) {
				if (dval < dMin) dMin = dval;
				if (dval > dMax) dMax = dval;
			}
		}
		float range = dMax - dMin;
		if (range < 1e-6f) range = 1.0f;
		for (int i = 0; i < n; i++) {
			float dval = d[i];
			float t = (dval <= 0.0f || dval >= 1e38f) ? 0.0f : 1.0f - (dval - dMin) / range;
			uint8 R = (uint8)(t > 1.0f ? 255 : t < 0.0f ? 0 : (int)(t * 255.0f));
			uint8 G = (uint8)(t > 1.0f ? 255 : t < 0.0f ? 0 : (int)(t * 255.0f));
			uint8 B = (uint8)(t > 1.0f ? 255 : t < 0.0f ? 0 : (int)(t * 255.0f));
			fb[i] = 0xFF000000 | (Color)(R << 16) | (Color)(G << 8) | B;
		}
	}
}

