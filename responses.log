------------------------------------------------------------
void drawTile(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}

	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	const size_t rowBytes = (size_t)copyW * sizeof(uint32);
	int rows = copyH;
	int srcRow = srcY;
	int dstRow = y;
	int srcOffset = srcY * tile.width + srcX;
	int dstOffset = y * dstWidth + x;

	// Vectorize memcpy for 4x4 blocks
	const int block_size = 16; // 16 uint32s
	const int blocks = (rows + block_size - 1) / block_size;

	for (int i = 0; i < blocks; i++) {
		int block = i * block_size;
		int block_end = block + block_size;
		if (block_end > rows) block_end = rows;

		// Hoist constants, use aligned access if possible
		const uint32 *src = tile.pixels + srcOffset + srcRow * tile.width;
		uint32 *dst = dst + dstRow * dstWidth + x;

		// Copy 16 uint32s at a time
		for (int j = 0; j < block_size; j++) {
			dst[j] = src[j];
		}
		srcRow += block_size;
		dstRow += block_size;
	}

	// Handle remaining rows
	for (int i = blocks * block_size; i < rows; i++) {
		int srcIdx = srcOffset + i * tile.width + srcX;
		int dstIdx = dstOffset + i * dstWidth + x;
		dst[dstIdx] = tile.pixels[srcIdx];
	}
}

