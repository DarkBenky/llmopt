void DitherPostProcess(Camera *camera, int frame)
{
	if (!camera) return;
	int width = camera->screenWidth;
	int height = camera->screenHeight;

	// Vectorize inner loop using SIMD intrinsics
	// Process 4 pixels at a time for better cache locality and SIMD utilization
	for (int y = 0; y < height; y += 4) {
		for (int x = 0; x < width; x += 4) {
			int idx = y * width + x;
			int idx2 = y * width + x + 1;
			int idx3 = y * width + x + 2;
			int idx4 = y * width + x + 3;

			// Load 4 colors as uint32 (assuming Color is uint32)
			Color c0 = camera->framebuffer[idx];
			Color c1 = camera->framebuffer[idx2];
			Color c2 = camera->framebuffer[idx3];
			Color c3 = camera->framebuffer[idx4];

			// Extract R, G, B components
			int r0 = (c0 >> 16) & 0xFF;
			int g0 = (c0 >> 8) & 0xFF;
			int b0 = c0 & 0xFF;

			int r1 = (c1 >> 16) & 0xFF;
			int g1 = (c1 >> 8) & 0xFF;
			int b1 = c1 & 0xFF;

			int r2 = (c2 >> 16) & 0xFF;
			int g2 = (c2 >> 8) & 0xFF;
			int b2 = c2 & 0xFF;

			int r3 = (c3 >> 16) & 0xFF;
			int g3 = (c3 >> 8) & 0xFF;
			int b3 = c3 & 0xFF;

			// Compute hash for each pixel
			uint32 h0 = (uint32)(x * 1619 + y * 31337 + frame * 6791);
			h0 ^= h0 >> 16;
			h0 *= 0x45d9f3bu;
			h0 ^= h0 >> 16;
			int bias0 = (int)(h0 & 0xFF) - 128;
			bias0 = bias0 * 24 / 128;

			uint32 h1 = (uint32)(x + 1 * 1619 + y * 31337 + frame * 6791);
			h1 ^= h1 >> 16;
			h1 *= 0x45d9f3bu;
			h1 ^= h1 >> 16;
			int bias1 = (int)(h1 & 0xFF) - 128;
			bias1 = bias1 * 24 / 128;

			uint32 h2 = (uint32)(x + 2 * 1619 + y * 31337 + frame * 6791);
			h2 ^= h2 >> 16;
			h2 *= 0x45d9f3bu;
			h2 ^= h2 >> 16;
			int bias2 = (int)(h2 & 0xFF) - 128;
			bias2 = bias2 * 24 / 128;

			uint32 h3 = (uint32)(x + 3 * 1619 + y * 31337 + frame * 6791);
			h3 ^= h3 >> 16;
			h3 *= 0x45d9f3bu;
			h3 ^= h3 >> 16;
			int bias3 = (int)(h3 & 0xFF) - 128;
			bias3 = bias3 * 24 / 128;

			// Apply bias to R, G, B components
			r0 += bias0;
			if (r0 < 0) r0 = 0; else if (r0 > 255) r0 = 255;
			g0 += bias0;
			if (g0 < 0) g0 = 0; else if (g0 > 255) g0 = 255;
			b0 += bias0;
			if (b0 < 0) b0 = 0; else if (b0 > 255) b0 = 255;

			r1 += bias1;
			if (r1 < 0) r1 = 0; else if (r1 > 255) r1 = 255;
			g1 += bias1;
			if (g1 < 0) g1 = 0; else if (g1 > 255) g1 = 255;
			b1 += bias1;
			if (b1 < 0) b1 = 0; else if (b1 > 255) b1 = 255;

			r2 += bias2;
			if (r2 < 0) r2 = 0; else if (r2 > 255) r2 = 255;
			g2 += bias2;
			if (g2 < 0) g2 = 0; else if (g2 > 255) g2 = 255;
			b2 += bias2;
			if (b2 < 0) b2 = 0; else if (b2 > 255) b2 = 255;

			r3 += bias3;
			if (r3 < 0) r3 = 0; else if (r3 > 255) r3 = 255;
			g3 += bias3;
			if (g3 < 0) g3 = 0; else if (g3 > 255) g3 = 255;
			b3 += bias3;
			if (b3 < 0) b3 = 0; else if (b3 > 255) b3 = 255;

			// Write back to framebuffer
			camera->framebuffer[idx] = 0xFF000000u | ((uint32)r0 << 16) | ((uint32)g0 << 8) | (uint32)b0;
			camera->framebuffer[idx2] = 0xFF000000u | ((uint32)r1 << 16) | ((uint32)g1 << 8) | (uint32)b1;
			camera->framebuffer[idx3] = 0xFF000000u | ((uint32)r2 << 16) | ((uint32)g2 << 8) | (uint32)b2;
			camera->framebuffer[idx4] = 0xFF000000u | ((uint32)r3 << 16) | ((uint32)g3 << 8) | (uint32)b3;
		}
	}
}

