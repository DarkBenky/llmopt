step=47  func=rayAABB  reward=-0.1068
------------------------------------------------------------
static float rayAABB(float3 ro, float3 rd, float3 mn, float3 mx)
{
	__m128 ro_vec = _mm_load_ps(&ro.x);
	__m128 rd_vec = _mm_load_ps(&rd.x);
	__m128 mn_vec = _mm_load_ps(&mn.x);
	__m128 mx_vec = _mm_load_ps(&mx.x);
	
	__m128 tmin_vec = _mm_set1_ps(0.0f);
	__m128 tmax_vec = _mm_set1_ps(FLT_MAX);
	
	for (int i = 0; i < 3; i++) {
		float d = rd_vec[i];
		float o = ro_vec[i];
		float bmin = mn_vec[i];
		float bmax = mx_vec[i];
		
		if (fabsf(d) < 1e-8f) {
			if (o < bmin || o > bmax) return FLT_MAX;
			continue;
		}
		
		__m128 invD = _mm_set1_ps(1.0f / d);
		__m128 t0 = _mm_mul_ps(_mm_sub_ps(_mm_set1_ps(bmin), _mm_set1_ps(o)), invD);
		__m128 t1 = _mm_mul_ps(_mm_sub_ps(_mm_set1_ps(bmax), _mm_set1_ps(o)), invD);
		
		__m128 t0t1 = _mm_shuffle_ps(t0, t1, _MM_SHUFFLE(0, 0, 0, 0));
		__m128 t1t0 = _mm_shuffle_ps(t0, t1, _MM_SHUFFLE(2, 2, 2, 2));
		__m128 tmp = _mm_max_ps(t0t1, t1t0);
		__m128 tmp2 = _mm_min_ps(t0t1, t1t0);
		
		__m128 tmin_tmp = _mm_max_ps(tmin_vec, tmp);
		__m128 tmax_tmp = _mm_min_ps(tmax_vec, tmp2);
		
		tmin_vec = tmin_tmp;
		tmax_vec = tmax_tmp;
		
		if (_mm_movemask_ps(_mm_or_ps(_mm_cmplt_ps(tmin_vec, tmax_vec), _mm_set1_ps(1.0f))) == 0) {
			return FLT_MAX;
		}
	}
	
	__m128 tmin_final = _mm_load_ps(&tmin_vec);
	__m128 tmax_final = _mm_load_ps(&tmax_vec);
	
	return _mm_cvtss_f32(_mm_max_ps(tmin_final, tmax_final));
}

