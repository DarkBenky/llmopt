step=829  func=ApplyRotMat3  reward=0.0055
------------------------------------------------------------
static inline float3 ApplyRotMat3(float3 v, RotMat3 m)
{
	float x = v.x, y = v.y, z = v.z;
	float r00 = m.m[0][0], r01 = m.m[0][1], r02 = m.m[0][2];
	float r10 = m.m[1][0], r11 = m.m[1][1], r12 = m.m[1][2];
	float r20 = m.m[2][0], r21 = m.m[2][1], r22 = m.m[2][2];
	return (float3){
		r00 * x + r01 * y + r02 * z,
		r10 * x + r11 * y + r12 * z,
		r20 * x + r21 * y + r22 * z
	};
}

