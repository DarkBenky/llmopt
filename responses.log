void drawTile(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}

	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	const size_t rowBytes = (size_t)copyW * sizeof(uint32);
	const int maxRows = copyH;
	const int maxCols = copyW;

	// Vectorize memcpy for 4x4 blocks
	const int simdWidth = 4;
	const int simdRows = 16;
	const int simdCols = 4;

	if (copyH >= simdRows && copyW >= simdCols) {
		const __m128i *src = (const __m128i *)tile.pixels;
		uint32 *dstBase = dst + y * dstWidth + x;
		int srcY0 = srcY, srcX0 = srcX;
		int dstY0 = y, dstX0 = x;

		for (int row = 0; row < copyH; row += simdRows) {
			const int rows = (copyH - row) > simdRows ? simdRows : copyH - row;
			const int cols = copyW;

			// Hoist loop invariants
			const __m128i *srcPtr = src + srcY0 * tile.width + srcX0;
			uint32 *dstPtr = dstBase + row * dstWidth;

			for (int col = 0; col < cols; col += simdCols) {
				const int colsInBlock = (cols - col) > simdCols ? simdCols : cols - col;
				const __m128i *srcBlock = srcPtr + col;
				uint32 *dstBlock = dstPtr + col;

				// Unroll 4x
				for (int i = 0; i < colsInBlock; i += 4) {
					const __m128i val0 = _mm_loadu_si128(srcBlock + i);
					const __m128i val1 = _mm_loadu_si128(srcBlock + i + 1);
					const __m128i val2 = _mm_loadu_si128(srcBlock + i + 2);
					const __m128i val3 = _mm_loadu_si128(srcBlock + i + 3);
					_mm_storeu_si128(dstBlock + i, val0);
					_mm_storeu_si128(dstBlock + i + 1, val1);
					_mm_storeu_si128(dstBlock + i + 2, val2);
					_mm_storeu_si128(dstBlock + i + 3, val3);
				}
			}
		}
	} else {
		const size_t rowBytes = (size_t)copyW * sizeof(uint32);
		for (int row = 0; row < copyH; row++) {
			memcpy(
				dst + (y + row) * dstWidth + x,
				tile.pixels + (srcY + row) * tile.width + srcX,
				rowBytes);
		}
	}
}

