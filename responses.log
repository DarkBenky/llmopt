step=586  func=DecimateBuffer  reward=-0.0188
------------------------------------------------------------
static inline void DecimateBuffer(float3 *src, float3 *dst, int width, int height, int factor)
{
	int dstWidth = width / factor;
	int dstHeight = height / factor;
	float invSamples = 1.0f / (float)(factor * factor);
	__m128i zero = _mm_setzero_ps();
	__m128i zero2 = _mm_setzero_ps();
	for (int y = 0; y < dstHeight; y++) {
		for (int x = 0; x < dstWidth; x++) {
			__m128 accum_x = _mm_setzero_ps();
			__m128 accum_y = _mm_setzero_ps();
			__m128 accum_z = _mm_setzero_ps();
			for (int ky = 0; ky < factor; ky++) {
				const float3 *row = src + (y * factor + ky) * width + x * factor;
				for (int kx = 0; kx < factor; kx++) {
					__m128 val_x = _mm_load_ps(&row[kx].x);
					__m128 val_y = _mm_load_ps(&row[kx].y);
					__m128 val_z = _mm_load_ps(&row[kx].z);
					accum_x = _mm_add_ps(accum_x, val_x);
					accum_y = _mm_add_ps(accum_y, val_y);
					accum_z = _mm_add_ps(accum_z, val_z);
				}
			}
			__m128 result_x = _mm_mul_ps(accum_x, _mm_set_ps1(invSamples));
			__m128 result_y = _mm_mul_ps(accum_y, _mm_set_ps1(invSamples));
			__m128 result_z = _mm_mul_ps(accum_z, _mm_set_ps1(invSamples));
			_mm_store_ps(&dst[y * dstWidth + x].x, result_x);
			_mm_store_ps(&dst[y * dstWidth + x].y, result_y);
			_mm_store_ps(&dst[y * dstWidth + x].z, result_z);
		}
	}
}

