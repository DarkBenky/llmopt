step=355  func=InverseRotateXYZ  reward=0.0069
------------------------------------------------------------
static inline float3 InverseRotateXYZ(float3 v, float3 rotation)
{
	float c1 = cosf(rotation.x);
	float s1 = sinf(rotation.x);
	float c2 = cosf(rotation.y);
	float s2 = sinf(rotation.y);
	float c3 = cosf(rotation.z);
	float s3 = sinf(rotation.z);
	
	float x = v.x;
	float y = v.y;
	float z = v.z;
	
	// Apply RotateX(-rotation.x) first
	float temp_y = y * c1 - z * s1;
	float temp_z = y * s1 + z * c1;
	
	// Apply RotateY(-rotation.y) next
	float temp_x = temp_y * c2 - temp_z * s2;
	float temp_z2 = temp_y * s2 + temp_z * c2;
	
	// Apply RotateZ(-rotation.z) last
	float final_x = temp_x * c3 - temp_z2 * s3;
	float final_y = temp_x * s3 + temp_z2 * c3;
	float final_z = temp_z2;
	
	return (float3){
		final_x,
		final_y,
		final_z
	};
}

