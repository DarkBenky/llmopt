void VisualizeBuffer(const Camera *camera, int mode)
{
	if (mode == 0) return; 
	const int n = camera->screenWidth * camera->screenHeight;

	if (mode == 1) { 
		float3 nm;
		for (int i = 0; i < n; i++) {
			nm = camera->normalBuffer[i];
			camera->framebuffer[i] = PackColorSafe(
				nm.x * 0.5f + 0.5f,
				nm.y * 0.5f + 0.5f,
				nm.z * 0.5f + 0.5f);
		}
		return;
	}

	if (mode == 3) { 
		float3 r;
		for (int i = 0; i < n; i++) {
			r = camera->reflectBuffer[i];
			camera->framebuffer[i] = PackColorSafe(
				r.x * 0.5f + 0.5f,
				r.y * 0.5f + 0.5f,
				r.z * 0.5f + 0.5f);
		}
		return;
	}

	if (mode == 2) { 
		float dMin = 1e38f, dMax = 0.0f;
		for (int i = 0; i < n; i++) {
			float d = camera->depthBuffer[i];
			if (d > 0.0f && d < 1e38f) {
				if (d < dMin) dMin = d;
				if (d > dMax) dMax = d;
			}
		}
		float range = dMax - dMin;
		if (range < 1e-6f) range = 1.0f;
		for (int i = 0; i < n; i++) {
			float d = camera->depthBuffer[i];
			float t = (d <= 0.0f || d >= 1e38f) ? 0.0f : 1.0f - (d - dMin) / range;
			camera->framebuffer[i] = PackColorSafe(t, t, t);
		}
	}
}

