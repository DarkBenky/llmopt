------------------------------------------------------------
void VisualizeBuffer(const Camera *camera, int mode)
{
	if (mode == 0) return; 
	const int n = camera->screenWidth * camera->screenHeight;

	if (mode == 1) { 
		const float3 *normalBuffer = camera->normalBuffer;
		Color *framebuffer = camera->framebuffer;
		const int stride = 3;
		const int n32 = n / 4;
		for (int i = 0; i < n32; i++) {
			float3 nm = normalBuffer[i * 4];
			framebuffer[i * 4] = PackColorSafe(
				nm.x * 0.5f + 0.5f,
				nm.y * 0.5f + 0.5f,
				nm.z * 0.5f + 0.5f);
			nm = normalBuffer[i * 4 + 1];
			framebuffer[i * 4 + 1] = PackColorSafe(
				nm.x * 0.5f + 0.5f,
				nm.y * 0.5f + 0.5f,
				nm.z * 0.5f + 0.5f);
			nm = normalBuffer[i * 4 + 2];
			framebuffer[i * 4 + 2] = PackColorSafe(
				nm.x * 0.5f + 0.5f,
				nm.y * 0.5f + 0.5f,
				nm.z * 0.5f + 0.5f);
			nm = normalBuffer[i * 4 + 3];
			framebuffer[i * 4 + 3] = PackColorSafe(
				nm.x * 0.5f + 0.5f,
				nm.y * 0.5f + 0.5f,
				nm.z * 0.5f + 0.5f);
		}
		return;
	}

	if (mode == 3) { 
		const float3 *reflectBuffer = camera->reflectBuffer;
		Color *framebuffer = camera->framebuffer;
		const int stride = 3;
		const int n32 = n / 4;
		for (int i = 0; i < n32; i++) {
			float3 r = reflectBuffer[i * 4];
			framebuffer[i * 4] = PackColorSafe(
				r.x * 0.5f + 0.5f,
				r.y * 0.5f + 0.5f,
				r.z * 0.5f + 0.5f);
			r = reflectBuffer[i * 4 + 1];
			framebuffer[i * 4 + 1] = PackColorSafe(
				r.x * 0.5f + 0.5f,
				r.y * 0.5f + 0.5f,
				r.z * 0.5f + 0.5f);
			r = reflectBuffer[i * 4 + 2];
			framebuffer[i * 4 + 2] = PackColorSafe(
				r.x * 0.5f + 0.5f,
				r.y * 0.5f + 0.5f,
				r.z * 0.5f + 0.5f);
			r = reflectBuffer[i * 4 + 3];
			framebuffer[i * 4 + 3] = PackColorSafe(
				r.x * 0.5f + 0.5f,
				r.y * 0.5f + 0.5f,
				r.z * 0.5f + 0.5f);
		}
		return;
	}

	if (mode == 2) { 
		float *depthBuffer = camera->depthBuffer;
		Color *framebuffer = camera->framebuffer;
		const int n32 = n / 4;
		float dMin = 1e38f, dMax = 0.0f;
		for (int i = 0; i < n32; i++) {
			float d = depthBuffer[i * 4];
			if (d > 0.0f && d < 1e38f) {
				if (d < dMin) dMin = d;
				if (d > dMax) dMax = d;
			}
			d = depthBuffer[i * 4 + 1];
			if (d > 0.0f && d < 1e38f) {
				if (d < dMin) dMin = d;
				if (d > dMax) dMax = d;
			}
			d = depthBuffer[i * 4 + 2];
			if (d > 0.0f && d < 1e38f) {
				if (d < dMin) dMin = d;
				if (d > dMax) dMax = d;
			}
			d = depthBuffer[i * 4 + 3];
			if (d > 0.0f && d < 1e38f) {
				if (d < dMin) dMin = d;
				if (d > dMax) dMax = d;
			}
		}
		float range = dMax - dMin;
		if (range < 1e-6f) range = 1.0f;
		for (int i = 0; i < n32; i++) {
			float d = depthBuffer[i * 4];
			float t = (d <= 0.0f || d >= 1e38f) ? 0.0f : 1.0f - (d - dMin) / range;
			framebuffer[i * 4] = PackColorSafe(t, t, t);
			d = depthBuffer[i * 4 + 1];
			t = (d <= 0.0f || d >= 1e38f) ? 0.0f : 1.0f - (d - dMin) / range;
			framebuffer[i * 4 + 1] = PackColorSafe(t, t, t);
			d = depthBuffer[i * 4 + 2];
			t = (d <= 0.0f || d >= 1e38f) ? 0.0f : 1.0f - (d - dMin) / range;
			framebuffer[i * 4 + 2] = PackColorSafe(t, t, t);
			d = depthBuffer[i * 4 + 3];
			t = (d <= 0.0f || d >= 1e38f) ? 0.0f : 1.0f - (d - dMin) / range;
			framebuffer[i * 4 + 3] = PackColorSafe(t, t, t);
		}
	}
}

