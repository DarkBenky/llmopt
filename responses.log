step=574  func=AdjustSaturation  reward=0.0017
------------------------------------------------------------
Color AdjustSaturation(Color c, float saturation)
{
	float3 col = UnpackColor(c);
	float gray = 0.299f * col.x + 0.587f * col.y + 0.114f * col.z;
	float scale = saturation;
	float bias = (1.0f - saturation) * gray;
	col.x = col.x * scale + bias;
	col.y = col.y * scale + bias;
	col.z = col.z * scale + bias;
	return PackColorF(col);
}

