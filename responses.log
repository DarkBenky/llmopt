void drawTile(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}

	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	const size_t rowBytes = (size_t)copyW * sizeof(uint32);
	int copyH_ = copyH;
	for (int row = 0; row < copyH_; row++) {
		int dstOff = (y + row) * dstWidth + x;
		int srcOff = (srcY + row) * tile.width + srcX;
		__m128i *dstVec = (__m128i *) (dst + dstOff);
		__m128i *srcVec = (__m128i *) (tile.pixels + srcOff);
		int vecCount = copyW / 4;
		for (int vec = 0; vec < vecCount; vec++) {
			*dstVec = *srcVec;
			dstVec++;
			srcVec++;
		}
		int rem = copyW % 4;
		if (rem > 0) {
			for (int i = 0; i < rem; i++) {
				dst[dstOff + i] = tile.pixels[srcOff + i];
			}
		}
	}
}

