------------------------------------------------------------
void Object_SetMaterial(Object *obj, MaterialLib *lib, Material mat)
{
	int count = obj->triangleCount;
	int *materialIds = obj->materialIds;
	Material *entries = lib->entries;

	// Hoist the material assignment to avoid cache misses per iteration
	// Use loop unrolling for better instruction-level parallelism
	for (int i = 0; i < count; i += 4) {
		entries[materialIds[i]] = mat;
		entries[materialIds[i+1]] = mat;
		entries[materialIds[i+2]] = mat;
		entries[materialIds[i+3]] = mat;
	}
}

