step=392  func=BlurColorBuffer  reward=-0.0237
------------------------------------------------------------
static void BlurColorBuffer(Color *src, Color *temp, int width, int height, int radius)
{
	if (radius <= 0) return;

	// Precompute bounds for x-direction blur
	int x0, x1;
	x0 = -radius;
	x1 = radius;
	if (x0 < 0) x0 = 0;
	if (x1 >= width) x1 = width - 1;

	// Precompute bounds for y-direction blur
	int y0, y1;
	y0 = -radius;
	y1 = radius;
	if (y0 < 0) y0 = 0;
	if (y1 >= height) y1 = height - 1;

	// First pass: blur horizontally
	for (int y = 0; y < height; y++) {
		const Color *row = src + y * width;
		Color *out = temp + y * width;
		for (int x = 0; x < width; x++) {
			uint32 r = 0, g = 0, b = 0, n = 0;
			for (int k = x - radius; k <= x + radius; k++) {
				if (k < 0 || k >= width) continue;
				Color c = row[k];
				if (!c) continue;
				r += (c >> 16) & 0xFF;
				g += (c >> 8) & 0xFF;
				b += c & 0xFF;
				n++;
			}
			out[x] = n ? (0xFF000000u | ((r / n) << 16) | ((g / n) << 8) | (b / n)) : 0;
		}
	}

	// Second pass: blur vertically
	for (int y = 0; y < height; y++) {
		for (int x = 0; x < width; x++) {
			uint32 r = 0, g = 0, b = 0, n = 0;
			for (int k = y - radius; k <= y + radius; k++) {
				if (k < 0 || k >= height) continue;
				Color c = temp[k * width + x];
				if (!c) continue;
				r += (c >> 16) & 0xFF;
				g += (c >> 8) & 0xFF;
				b += c & 0xFF;
				n++;
			}
			src[y * width + x] = n ? (0xFF000000u | ((r / n) << 16) | ((g / n) << 8) | (b / n)) : 0;
		}
	}
}

