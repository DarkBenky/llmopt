------------------------------------------------------------
void drawTileColor(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y, uint32 color)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}
	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	int srcStride = tile.width;
	int dstStride = dstWidth;

	// Hoist invariants, unroll loops for better cache locality and SIMD potential
	for (int row = 0; row < copyH; row++) {
		uint32 *dstLine = dst + (y + row) * dstStride;
		const uint32 *srcLine = tile.pixels + (srcY + row) * srcStride;

		// Unroll by 4 for 4x4 blocks, optimize memory access
		for (int col = 0; col < copyW; col += 4) {
			uint32 src0 = srcLine[col];
			uint32 src1 = srcLine[col + 1];
			uint32 src2 = srcLine[col + 2];
			uint32 src3 = srcLine[col + 3];

			if (src0 != 0x00000000) dstLine[col] = color;
			if (src1 != 0x00000000) dstLine[col + 1] = color;
			if (src2 != 0x00000000) dstLine[col + 2] = color;
			if (src3 != 0x00000000) dstLine[col + 3] = color;
		}
	}
}

