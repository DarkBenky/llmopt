static inline float3 RotateX(float3 v, float angle)
{
	float c = cosf(angle);
	float s = sinf(angle);
	float y = v.y, z = v.z;
	float y_c = y * c, z_s = z * s, y_s = y * s, z_c = z * c;
	return (float3){
