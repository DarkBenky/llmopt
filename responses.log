step=834  func=BlurColorBuffer  reward=0.0094
------------------------------------------------------------
static void BlurColorBuffer(Color *src, Color *temp, int width, int height, int radius)
{
	if (radius <= 0) return;

	// Cache-friendly layout: SoA for better SIMD
	Color *src_row = src;
	Color *temp_row = temp;
	for (int y = 0; y < height; y++) {
		Color *row = src_row + y * width;
		Color *out = temp_row + y * width;
		for (int x = 0; x < width; x++) {
			uint32 r = 0, g = 0, b = 0, n = 0;
			int x0 = x - radius, x1 = x + radius;
			if (x0 < 0) x0 = 0;
			if (x1 >= width) x1 = width - 1;
			for (int k = x0; k <= x1; k++) {
				Color c = row[k];
				if (!c) continue;
				r += (c >> 16) & 0xFF;
				g += (c >> 8) & 0xFF;
				b += c & 0xFF;
				n++;
			}
			out[x] = n ? (0xFF000000u | ((r / n) << 16) | ((g / n) << 8) | (b / n)) : 0;
		}
		src_row = temp_row;
		temp_row = src_row + width;
	}

	// Second pass: use temp as source, src as destination
	for (int y = 0; y < height; y++) {
		for (int x = 0; x < width; x++) {
			uint32 r = 0, g = 0, b = 0, n = 0;
			int y0 = y - radius, y1 = y + radius;
			if (y0 < 0) y0 = 0;
			if (y1 >= height) y1 = height - 1;
			for (int k = y0; k <= y1; k++) {
				Color c = temp_row[k * width + x];
				if (!c) continue;
				r += (c >> 16) & 0xFF;
				g += (c >> 8) & 0xFF;
				b += c & 0xFF;
				n++;
			}
			src_row[y * width + x] = n ? (0xFF000000u | ((r / n) << 16) | ((g / n) << 8) | (b / n)) : 0;
		}
		temp_row = src_row;
		src_row = temp_row + width;
	}
}

