Color ApplyGamma(Color c, float gamma)
{
	float3 col = UnpackColor(c);
	__m128 m1 = _mm_set_ps(0.0f, col.z, col.y, col.x);
	__m128 m2 = _mm_set_ps(0.0f, 1.0f / gamma, 1.0f / gamma, 1.0f / gamma);
	__m128 m3 = _mm_mul_ps(m1, m2);
	col.x = _mm_cvtss_f32(_mm_shuffle_ps(m3, m3, _MM_SHUFFLE(2, 3, 1, 0)));
	col.y = _mm_cvtss_f32(_mm_shuffle_ps(m3, m3, _MM_SHUFFLE(3, 2, 0, 1)));
	col.z = _mm_cvtss_f32(_mm_shuffle_ps(m3, m3, _MM_SHUFFLE(1, 0, 3, 2)));
	return PackColorF(col);
}

