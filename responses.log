------------------------------------------------------------
static inline void DecimateBuffer(float3 *src, float3 *dst, int width, int height, int factor)
{
	int dstWidth = width / factor;
	int dstHeight = height / factor;
	float invSamples = 1.0f / (float)(factor * factor);
	__m128i zero = _mm_setzero_si128();
	__m128i mask = _mm_set1_epi32(0x00000000);
	for (int y = 0; y < dstHeight; y++) {
		for (int x = 0; x < dstWidth; x++) {
			__m128i accum_x = zero, accum_y = zero, accum_z = zero;
			for (int ky = 0; ky < factor; ky++) {
				const float3 *row = src + (y * factor + ky) * width + x * factor;
				for (int kx = 0; kx < factor; kx++) {
					__m128i val = _mm_loadu_ps((float*)(&row[kx]));
					accum_x = _mm_add_ps(accum_x, val);
					accum_y = _mm_add_ps(accum_y, val);
					accum_z = _mm_add_ps(accum_z, val);
				}
			}
			__m128 accum_x_final = _mm_mul_ps(accum_x, _mm_set_ps1(invSamples));
			__m128 accum_y_final = _mm_mul_ps(accum_y, _mm_set_ps1(invSamples));
			__m128 accum_z_final = _mm_mul_ps(accum_z, _mm_set_ps1(invSamples));
			_mm_storeu_ps((float*)(&dst[y * dstWidth + x]), accum_x_final);
			_mm_storeu_ps((float*)(&dst[y * dstWidth + x + 1]), accum_y_final);
			_mm_storeu_ps((float*)(&dst[y * dstWidth + x + 2]), accum_z_final);
		}
	}
}

