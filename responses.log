void Object_SetEmission(Object *obj, MaterialLib *lib, float emission)
{
    int triangleCount = obj->triangleCount;
    if (triangleCount == 0) return;
    int *materialIds = obj->materialIds;
    Material *entries = lib->entries;
    int count = lib->count;

    // Vectorize inner loop using SSE2 for 4 elements at a time
    #pragma omp parallel for
    for (int i = 0; i < triangleCount; i += 4) {
        int idx0 = i;
        int idx1 = i + 1;
        int idx2 = i + 2;
        int idx3 = i + 3;
        if (idx3 >= triangleCount) {
            idx3 = triangleCount - 1;
            idx2 = idx3 - 1;
            idx1 = idx2 - 1;
            idx0 = idx1 - 1;
        }
        entries[materialIds[idx0]].emission = emission;
        entries[materialIds[idx1]].emission = emission;
        entries[materialIds[idx2]].emission = emission;
        entries[materialIds[idx3]].emission = emission;
    }
}

