static inline float3 RotateXYZ(float3 v, float3 rotation)
{
	float c0 = cosf(rotation.x);
	float s0 = sinf(rotation.x);
	float c1 = cosf(rotation.y);
	float s1 = sinf(rotation.y);
	float c2 = cosf(rotation.z);
	float s2 = sinf(rotation.z);

	float x = v.x;
	float y = v.y;
	float z = v.z;

	// Apply Z rotation first (most efficient for SIMD)
	float x1 = x * c2 - z * s2;
	float z1 = x * s2 + z * c2;
	float y1 = y;

	// Apply Y rotation
	float x2 = x1 * c1 + z1 * s1;
	float z2 = x1 * s1 - z1 * c1;
	float y2 = y1;

	// Apply X rotation
	float x3 = x2;
	float y3 = y2 * c0 - z2 * s0;
	float z3 = y2 * s0 + z2 * c0;

	return (float3){x3, y3, z3};
}

