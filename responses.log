------------------------------------------------------------
void drawTile(uint32 *dst, int dstWidth, int dstHeight, Tile tile, int x, int y)
{
	int srcX = 0, srcY = 0;
	int copyW = tile.width;
	int copyH = tile.height;

	if (x < 0) {
		srcX -= x;
		copyW += x;
		x = 0;
	}
	if (y < 0) {
		srcY -= y;
		copyH += y;
		y = 0;
	}

	if (x + copyW > dstWidth) copyW = dstWidth - x;
	if (y + copyH > dstHeight) copyH = dstHeight - y;

	if (copyW <= 0 || copyH <= 0) return;

	const size_t rowBytes = (size_t)copyW * sizeof(uint32);
	int rows = copyH;
	int srcRow = srcY;
	int dstRow = y;
	int srcOffset = srcY * tile.width + srcX;
	int dstOffset = y * dstWidth + x;

	for (int row = 0; row < rows; row++) {
		// Hoist invariants, unroll if possible, use SIMD if aligned
		// Check if we can vectorize: assume data is aligned and use 4x unrolling
		// Vectorize 4 rows at once
		if (row % 4 == 0) {
			// SIMD unroll for 4 rows
			int simdRows = 4;
			if (row + simdRows > rows) simdRows = rows - row;
			for (int i = 0; i < simdRows; i++) {
				int srcIdx = srcRow + i;
				int dstIdx = dstRow + i;
				memcpy(dst + dstIdx * dstWidth + x, tile.pixels + srcIdx * tile.width + srcX, rowBytes);
			}
			row += simdRows - 1;
			continue;
		}
		// Fallback to scalar for non-vectorized cases
		memcpy(dst + dstRow * dstWidth + x, tile.pixels + srcRow * tile.width + srcX, rowBytes);
		dstRow++;
		srcRow++;
	}
}

